---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { getAdminSession, isAuthConfigured } from '../lib/server/auth';

export const prerender = false;

const session = await getAdminSession(Astro.request);
const authenticated = Boolean(session);
const configured = isAuthConfigured();
---

<BaseLayout title="Админ-панель" noindex bodyClass="admin-page-shell" forceTheme="light">
  <main id="main" class="admin-page">
    <section class="admin-panel">
      <div class="admin-panel__top">
        <a href="/" class="admin-panel__logo" aria-label="На главную">
          <img src="/logos/logo_short_black.png" alt="" width="1058" height="411" />
        </a>
        <a class="admin-panel__site-link" href="/">
          На сайт
          <Icon name="arrow-right" size={18} />
        </a>
      </div>

      {!authenticated ? (
        <div class="admin-login" data-admin-login>
          <div class="admin-login__copy">
            <p class="admin-eyebrow">Управление</p>
            <h1>Админ-панель</h1>
            <p>
              Войдите, чтобы добавлять, редактировать и удалять новости сайта.
            </p>
            {!configured && (
              <p class="admin-warning">
                Авторизация не настроена. Добавьте ADMIN_LOGIN, ADMIN_PASSWORD_HASH
                и AUTH_SECRET в .env.
              </p>
            )}
          </div>

          <form class="admin-form admin-form--login" data-login-form>
            <label>
              <span>Логин</span>
              <input name="login" type="text" autocomplete="username" required />
            </label>
            <label>
              <span>Пароль</span>
              <input
                name="password"
                type="password"
                autocomplete="current-password"
                required
              />
            </label>
            <button class="admin-primary" type="submit" disabled={!configured}>
              Войти
            </button>
            <p class="admin-message" data-login-message aria-live="polite"></p>
          </form>
        </div>
      ) : (
        <div class="admin-app" data-admin-app>
          <div class="admin-app__header">
            <div>
              <h1>Админ-панель</h1>
            </div>
            <div class="admin-app__actions">
              <Button href="/news" variant="secondary">
                Все новости
                <Icon name="arrow-right" size={18} />
              </Button>
              <button class="admin-secondary" type="button" data-logout>
                Выйти
              </button>
            </div>
          </div>

          <p class="admin-message" data-admin-message aria-live="polite"></p>

          <div class="admin-layout">
            <div class="admin-layout__main">
            <section class="admin-card admin-card--form">
              <div class="admin-card__head">
                <div>
                  <p class="admin-eyebrow">Форма</p>
                  <h2 data-form-title>Добавить новость</h2>
                </div>
                <button class="admin-secondary" type="button" data-new-news>
                  Добавить новость
                </button>
              </div>

              <form class="admin-form" data-news-form>
                <input type="hidden" name="id" />

                <label>
                  <span>Заголовок *</span>
                  <input name="title" type="text" maxlength="220" required />
                </label>

                <div class="admin-form__grid">
                  <label>
                    <span>Дата публикации *</span>
                    <input name="date" type="date" required />
                  </label>
                  <label>
                    <span>Статус</span>
                    <select name="isPublished">
                      <option value="true">Опубликовано</option>
                      <option value="false">Черновик</option>
                    </select>
                  </label>
                </div>

                <div
                  class="admin-upload"
                  data-upload-zone
                >
                  <input
                    class="admin-upload__input"
                    data-upload-input
                    type="file"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    multiple
                  />
                  <input type="hidden" name="images" data-images-value />
                  <div class="admin-upload__text">
                    <span>Изображения</span>
                    <p>Перетащите картинки сюда или прикрепите через скрепку</p>
                    <small>JPG, PNG, WEBP, GIF до 20 МБ. Первая картинка будет главной.</small>
                  </div>
                  <button class="admin-upload__button" type="button" data-upload-button>
                    <Icon name="paperclip" size={17} />
                    Прикрепить
                  </button>
                </div>

                <div
                  class="admin-upload-preview"
                  data-upload-preview
                  aria-live="polite"
                ></div>

                <label>
                  <span>Короткое описание *</span>
                  <textarea name="excerpt" rows="3" maxlength="600" required></textarea>
                </label>

                <label>
                  <span>Полный текст *</span>
                  <textarea
                    name="content"
                    rows="9"
                    placeholder="Разделяйте абзацы пустой строкой"
                    required
                  ></textarea>
                </label>

                <div class="admin-form__buttons">
                  <button class="admin-primary" type="submit">Сохранить</button>
                  <button class="admin-secondary" type="button" data-cancel-edit>
                    Отмена
                  </button>
                </div>
              </form>
            </section>

            <section class="admin-card admin-settings" aria-labelledby="admin-settings-title">
              <div class="admin-card__head">
                <div>
                  <p class="admin-eyebrow">Настройки формы</p>
                  <h2 id="admin-settings-title">Получатель заявок</h2>
                </div>
              </div>

              <form class="admin-form admin-settings__form" data-settings-form>
                <label>
                  <span>Email для заявок *</span>
                  <input
                    name="contactEmail"
                    type="email"
                    autocomplete="email"
                    required
                    data-settings-email
                  />
                </label>
                <button class="admin-primary" type="submit">
                  Сохранить
                </button>
                <p class="admin-message" data-settings-message aria-live="polite"></p>
              </form>
            </section>
            </div>

            <section class="admin-card admin-card--list">
              <div class="admin-card__head">
                <div>
                  <p class="admin-eyebrow">Список</p>
                  <h2>Новости</h2>
                </div>
                <span class="admin-count" data-news-count>0</span>
              </div>

              <div class="admin-news-list" data-news-list>
                <p class="admin-muted">Загрузка новостей...</p>
              </div>
            </section>
          </div>
        </div>
      )}
    </section>
  </main>
</BaseLayout>

<style>
  :global(.admin-page-shell) {
    background: #f8fafc;
  }

  .admin-page {
    min-height: 100svh;
    padding: clamp(14px, 2.4vw, 28px);
    color: #0f172a;
    font-size: 0.84rem;
    font-weight: 500;
  }

  .admin-panel {
    width: min(1680px, 100%);
    margin: 0 auto;
  }

  .admin-panel__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: clamp(16px, 2.2vw, 26px);
  }

  .admin-panel__logo {
    display: inline-flex;
    width: 102px;
  }

  .admin-panel__logo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .admin-panel__site-link,
  :global(.admin-secondary),
  :global(.admin-primary) {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 8px;
    padding: 0 12px;
    font-size: 0.84rem;
    font-weight: 500;
    text-decoration: none;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .admin-panel__site-link,
  :global(.admin-secondary) {
    border: 1px solid rgb(15 23 42 / 0.14);
    background: rgb(255 255 255 / 0.76);
    color: #1e3a8a;
  }

  :global(.admin-primary) {
    border: 1px solid #1d4ed8;
    background: #1d4ed8;
    color: #fff;
  }

  :global(.admin-primary:disabled) {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .admin-panel__site-link:hover,
  :global(.admin-secondary:hover),
  :global(.admin-primary:hover:not(:disabled)) {
    transform: translateY(-1px);
  }

  .admin-login,
  .admin-app {
    border: 1px solid rgb(15 23 42 / 0.12);
    border-radius: 12px;
    background: rgb(255 255 255 / 0.86);
    box-shadow: 0 24px 70px rgb(15 23 42 / 0.08);
  }

  .admin-login {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 420px);
    gap: clamp(24px, 4vw, 56px);
    padding: clamp(20px, 3.8vw, 50px);
  }

  .admin-login__copy h1,
  .admin-app__header h1 {
    margin: 0;
    color: #004329;
    font-size: clamp(1.8rem, 4.3vw, 3.9rem);
    font-weight: 700;
    line-height: 0.94;
    text-transform: uppercase;
  }

  .admin-login__copy p {
    max-width: 540px;
    margin: 18px 0 0;
    color: rgb(15 23 42 / 0.72);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .admin-eyebrow {
    margin: 0 0 8px;
    color: #64748b;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .admin-warning {
    border-left: 3px solid #b80008;
    padding-left: 12px;
    color: #b80008 !important;
  }

  .admin-app {
    padding: clamp(16px, 2.4vw, 28px);
  }

  .admin-app__header,
  .admin-card__head,
  .admin-form__buttons,
  .admin-app__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .admin-app__actions,
  .admin-form__buttons {
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .admin-app__actions :global(a) {
    min-height: 32px;
    border-radius: 8px;
    padding: 0 12px;
    font-size: 0.84rem;
    font-weight: 500;
  }

  .admin-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(360px, 0.75fr);
    align-items: start;
    gap: clamp(14px, 1.7vw, 24px);
    margin-top: 18px;
  }

  .admin-layout__main {
    display: grid;
    min-width: 0;
    gap: 18px;
  }

  .admin-settings__form {
    grid-template-columns: minmax(260px, 1fr) auto;
    align-items: end;
    gap: 12px;
  }

  .admin-settings__form .admin-message {
    grid-column: 1 / -1;
    margin-top: 0;
  }

  .admin-card {
    border: 1px solid rgb(15 23 42 / 0.12);
    border-radius: 10px;
    background: #fff;
    padding: clamp(14px, 1.6vw, 18px);
  }

  .admin-card--form,
  .admin-card--list {
    min-width: 0;
  }

  .admin-card__head {
    margin-bottom: 14px;
  }

  .admin-card__head h2 {
    margin: 0;
    color: #004329;
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.1;
  }

  .admin-form {
    display: grid;
    gap: 10px;
  }

  .admin-form label {
    display: grid;
    gap: 6px;
  }

  .admin-form span {
    color: #004329;
    font-size: 0.76rem;
    font-weight: 500;
  }

  .admin-form small {
    color: #64748b;
    font-size: 0.66rem;
    line-height: 1.35;
  }

  .admin-form input,
  .admin-form select,
  .admin-form textarea {
    width: 100%;
    border: 1px solid rgb(15 23 42 / 0.18);
    border-radius: 8px;
    background: #fff;
    color: #0f172a;
    font: inherit;
    padding: 8px 10px;
    outline: none;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .admin-form textarea {
    resize: vertical;
  }

  .admin-form input:focus,
  .admin-form select:focus,
  .admin-form textarea:focus {
    border-color: rgb(29 78 216 / 0.72);
    box-shadow: 0 0 0 3px rgb(29 78 216 / 0.12);
  }

  .admin-form__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
  }

  .admin-upload {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    border: 1px dashed rgb(15 23 42 / 0.22);
    border-radius: 10px;
    background: rgb(248 250 252 / 0.76);
    padding: 14px;
    transition:
      background-color 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .admin-upload.is-dragover {
    border-color: rgb(29 78 216 / 0.72);
    background: rgb(29 78 216 / 0.05);
    box-shadow: 0 0 0 3px rgb(29 78 216 / 0.12);
  }

  .admin-upload__input {
    position: absolute;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .admin-upload__text {
    display: grid;
    gap: 3px;
  }

  .admin-upload__text p,
  .admin-upload__text small {
    margin: 0;
    color: #64748b;
    font-size: 0.72rem;
    line-height: 1.35;
  }

  .admin-upload__button {
    display: inline-flex;
    min-height: 32px;
    align-items: center;
    justify-content: center;
    gap: 7px;
    border: 1px solid rgb(15 23 42 / 0.14);
    border-radius: 8px;
    background: #fff;
    color: #1e3a8a;
    font: inherit;
    font-weight: 500;
    padding: 0 12px;
    cursor: pointer;
  }

  .admin-upload-preview {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(112px, 1fr));
    gap: 9px;
  }

  .admin-upload-preview:empty {
    display: none;
  }

  :global(.admin-upload-thumb) {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border: 1px solid rgb(15 23 42 / 0.12);
    border-radius: 8px;
    background: #e2e8f0;
  }

  :global(.admin-upload-thumb img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.admin-upload-thumb__remove) {
    position: absolute;
    top: 6px;
    right: 6px;
    display: inline-flex;
    width: 24px;
    height: 24px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(15 23 42 / 0.14);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.92);
    color: #b80008;
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
  }

  .admin-message {
    min-height: 1.4em;
    margin: 10px 0 0;
    color: #b80008;
    font-weight: 500;
  }

  .admin-message[data-tone='success'] {
    color: #047857;
  }

  .admin-news-list {
    display: grid;
    max-height: 560px;
    gap: 10px;
    overflow: auto;
    padding-right: 4px;
  }

  :global(.admin-news-item) {
    display: grid;
    gap: 8px;
    border: 1px solid rgb(15 23 42 / 0.12);
    border-radius: 8px;
    padding: 12px;
  }

  :global(.admin-news-item__meta),
  :global(.admin-news-item__actions) {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  :global(.admin-news-item__date),
  :global(.admin-news-item__status),
  .admin-count {
    color: #64748b;
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.admin-news-item__status.is-draft) {
    color: #b80008;
  }

  :global(.admin-news-item h3) {
    margin: 0;
    color: #004329;
    font-size: 0.88rem;
    font-weight: 500;
    line-height: 1.25;
  }

  :global(.admin-news-item p) {
    margin: 0;
    color: rgb(15 23 42 / 0.68);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  :global(.admin-news-item__actions) {
    justify-content: flex-start;
  }

  :global(.admin-danger) {
    color: #b80008;
  }

  :global(.admin-muted) {
    margin: 0;
    color: #64748b;
  }

  @media (max-width: 980px) {
    .admin-login,
    .admin-layout {
      grid-template-columns: 1fr;
    }

    .admin-app__header {
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 640px) {
    .admin-page {
      padding: 12px;
    }

    .admin-login__copy h1,
    .admin-app__header h1 {
      font-size: clamp(1.8rem, 12vw, 2.7rem);
    }

    .admin-card__head,
    .admin-form__grid,
    .admin-settings__form {
      grid-template-columns: 1fr;
    }

    .admin-card__head {
      align-items: flex-start;
      flex-direction: column;
    }

    .admin-upload {
      grid-template-columns: 1fr;
    }

    .admin-upload__button {
      width: 100%;
    }
  }
</style>

<script>
  // @ts-nocheck
  const loginForm = document.querySelector<HTMLFormElement>('[data-login-form]');
  const loginMessage = document.querySelector<HTMLElement>('[data-login-message]');
  const adminApp = document.querySelector<HTMLElement>('[data-admin-app]');
  const newsForm = document.querySelector<HTMLFormElement>('[data-news-form]');
  const newsList = document.querySelector<HTMLElement>('[data-news-list]');
  const newsCount = document.querySelector<HTMLElement>('[data-news-count]');
  const adminMessage = document.querySelector<HTMLElement>('[data-admin-message]');
  const settingsForm = document.querySelector<HTMLFormElement>('[data-settings-form]');
  const settingsEmail = document.querySelector<HTMLInputElement>('[data-settings-email]');
  const settingsMessage = document.querySelector<HTMLElement>('[data-settings-message]');
  const formTitle = document.querySelector<HTMLElement>('[data-form-title]');
  const newButton = document.querySelector<HTMLButtonElement>('[data-new-news]');
  const cancelButton = document.querySelector<HTMLButtonElement>('[data-cancel-edit]');
  const logoutButton = document.querySelector<HTMLButtonElement>('[data-logout]');
  const uploadZone = document.querySelector<HTMLElement>('[data-upload-zone]');
  const uploadInput = document.querySelector<HTMLInputElement>('[data-upload-input]');
  const uploadButton = document.querySelector<HTMLButtonElement>('[data-upload-button]');
  const uploadPreview = document.querySelector<HTMLElement>('[data-upload-preview]');
  const imagesValue = document.querySelector<HTMLInputElement>('[data-images-value]');

  let newsItems = [];
  let selectedImages = [];

  const escapeHtml = (value) =>
    String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const setMessage = (node, message, tone = 'error') => {
    if (!node) return;

    node.textContent = message;
    node.dataset.tone = tone;
  };

  const requestJson = async (url, options = {}) => {
    const response = await fetch(url, {
      credentials: 'same-origin',
      ...options,
      headers: {
        'Content-Type': 'application/json',
        ...(options.headers ?? {}),
      },
    });
    const data = await response.json().catch(() => ({}));

    if (!response.ok || data.ok === false) {
      throw data;
    }

    return data;
  };

  const requestFormData = async (url, body) => {
    const response = await fetch(url, {
      method: 'POST',
      credentials: 'same-origin',
      body,
    });
    const data = await response.json().catch(() => ({}));

    if (!response.ok || data.ok === false) {
      throw data;
    }

    return data;
  };

  const syncImagesField = () => {
    if (imagesValue) {
      imagesValue.value = JSON.stringify(selectedImages);
    }
  };

  const renderImagePreview = () => {
    if (!uploadPreview) return;

    syncImagesField();

    uploadPreview.innerHTML = selectedImages
      .map(
        (image, index) => `
          <div class="admin-upload-thumb">
            <img src="${escapeHtml(image.src)}" alt="${escapeHtml(image.alt || 'Изображение новости')}" />
            <button
              class="admin-upload-thumb__remove"
              type="button"
              data-remove-image="${index}"
              aria-label="Удалить изображение"
            >
              ×
            </button>
          </div>
        `,
      )
      .join('');
  };

  const setSelectedImages = (images) => {
    selectedImages = images
      .filter((image) => image?.src)
      .map((image) => ({
        src: String(image.src),
        alt: String(image.alt || 'Изображение новости'),
      }))
      .slice(0, 12);
    renderImagePreview();
  };

  const uploadFiles = async (fileList) => {
    const files = Array.from(fileList ?? []).filter((file) =>
      file.type?.startsWith('image/'),
    );

    if (files.length === 0) return;

    const availableSlots = 12 - selectedImages.length;

    if (availableSlots <= 0) {
      setMessage(adminMessage, 'Можно добавить не больше 12 изображений.');
      return;
    }

    const formData = new FormData();
    files.slice(0, availableSlots).forEach((file) => formData.append('images', file));

    try {
      setMessage(adminMessage, 'Загружаем изображения...', 'success');
      const data = await requestFormData('/api/admin/uploads', formData);
      setSelectedImages([...selectedImages, ...(data.images ?? [])]);
      setMessage(adminMessage, 'Изображения добавлены.', 'success');
    } catch (error) {
      const messages = {
        no_files: 'Выберите изображения для загрузки.',
        too_many_files: 'За один раз можно загрузить не больше 12 изображений.',
        unsupported_file_type: 'Поддерживаются только JPG, PNG, WEBP и GIF.',
        file_too_large: 'Размер одного изображения не должен превышать 20 МБ.',
      };
      setMessage(
        adminMessage,
        messages[error?.error] || 'Не удалось загрузить изображения.',
      );
    } finally {
      if (uploadInput) uploadInput.value = '';
    }
  };

  const getFormData = () => {
    if (!newsForm) return null;

    const data = new FormData(newsForm);

    return {
      id: String(data.get('id') ?? ''),
      title: String(data.get('title') ?? '').trim(),
      date: String(data.get('date') ?? '').trim(),
      images: selectedImages,
      excerpt: String(data.get('excerpt') ?? '').trim(),
      content: String(data.get('content') ?? '').trim(),
      isPublished: data.get('isPublished') === 'true',
    };
  };

  const resetForm = () => {
    newsForm?.reset();
    if (newsForm) {
      newsForm.elements.namedItem('id').value = '';
      newsForm.elements.namedItem('isPublished').value = 'true';
    }
    setSelectedImages([]);
    if (formTitle) formTitle.textContent = 'Добавить новость';
  };

  const fillForm = (item) => {
    if (!newsForm) return;

    newsForm.elements.namedItem('id').value = item.id;
    newsForm.elements.namedItem('title').value = item.title;
    newsForm.elements.namedItem('date').value = item.date;
    newsForm.elements.namedItem('excerpt').value = item.excerpt;
    newsForm.elements.namedItem('content').value = item.content;
    newsForm.elements.namedItem('isPublished').value = String(item.isPublished);
    setSelectedImages(
      item.images?.length
        ? item.images
        : [{ src: item.image, alt: item.imageAlt || item.title }],
    );
    if (formTitle) formTitle.textContent = 'Редактировать новость';
    newsForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  const renderNews = () => {
    if (!newsList) return;

    if (newsCount) newsCount.textContent = String(newsItems.length);

    if (newsItems.length === 0) {
      newsList.innerHTML = '<p class="admin-muted">Новостей пока нет.</p>';
      return;
    }

    newsList.innerHTML = newsItems
      .map(
        (item) => `
          <article class="admin-news-item">
            <div class="admin-news-item__meta">
              <span class="admin-news-item__date">${escapeHtml(item.date)}</span>
              <span class="admin-news-item__status ${item.isPublished ? '' : 'is-draft'}">
                ${item.isPublished ? 'Опубликовано' : 'Черновик'}
              </span>
            </div>
            <h3>${escapeHtml(item.title)}</h3>
            <p>${escapeHtml(item.excerpt)}</p>
            <div class="admin-news-item__actions">
              <button class="admin-secondary" type="button" data-action="edit" data-id="${escapeHtml(item.id)}">
                Редактировать
              </button>
              <button class="admin-secondary admin-danger" type="button" data-action="delete" data-id="${escapeHtml(item.id)}">
                Удалить
              </button>
              <a class="admin-secondary" href="/news/${escapeHtml(item.slug)}" target="_blank" rel="noreferrer">
                Открыть
              </a>
            </div>
          </article>
        `,
      )
      .join('');
  };

  const loadNews = async () => {
    if (!adminApp) return;

    try {
      setMessage(adminMessage, 'Загрузка...', 'success');
      const data = await requestJson('/api/admin/news');
      newsItems = data.news ?? [];
      renderNews();
      setMessage(adminMessage, '', 'success');
    } catch (error) {
      setMessage(adminMessage, 'Не удалось загрузить новости. Возможно, сессия истекла.');
    }
  };

  const loadSettings = async () => {
    if (!adminApp || !settingsEmail) return;

    try {
      const data = await requestJson('/api/admin/settings');
      settingsEmail.value = data.settings?.contactEmail ?? '';
      setMessage(settingsMessage, '', 'success');
    } catch {
      setMessage(settingsMessage, 'Не удалось загрузить настройки формы.');
    }
  };

  loginForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = new FormData(loginForm);

    try {
      setMessage(loginMessage, 'Проверяем...', 'success');
      await requestJson('/api/admin/login', {
        method: 'POST',
        body: JSON.stringify({
          login: String(data.get('login') ?? ''),
          password: String(data.get('password') ?? ''),
        }),
      });
      window.location.reload();
    } catch (error) {
      const message =
        error?.error === 'auth_not_configured'
          ? 'Авторизация не настроена в .env'
          : 'Неверный логин или пароль';
      setMessage(loginMessage, message);
    }
  });

  settingsForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const contactEmail = settingsEmail?.value.trim() ?? '';

    try {
      setMessage(settingsMessage, 'Сохраняем...', 'success');
      const data = await requestJson('/api/admin/settings', {
        method: 'PUT',
        body: JSON.stringify({ contactEmail }),
      });
      if (settingsEmail) settingsEmail.value = data.settings?.contactEmail ?? contactEmail;
      setMessage(settingsMessage, 'Email для заявок сохранен.', 'success');
    } catch (error) {
      const errors = error?.errors ? Object.values(error.errors).join(' ') : '';
      setMessage(settingsMessage, errors || 'Не удалось сохранить настройки формы.');
    }
  });

  newsForm?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const payload = getFormData();
    if (!payload) return;

    try {
      setMessage(adminMessage, 'Сохраняем...', 'success');
      const isEditing = Boolean(payload.id);
      const url = isEditing ? `/api/admin/news/${encodeURIComponent(payload.id)}` : '/api/admin/news';
      const method = isEditing ? 'PUT' : 'POST';
      const { id, ...body } = payload;

      await requestJson(url, {
        method,
        body: JSON.stringify(body),
      });
      resetForm();
      await loadNews();
      setMessage(adminMessage, 'Новость сохранена.', 'success');
    } catch (error) {
      const errors = error?.errors ? Object.values(error.errors).join(' ') : '';
      setMessage(adminMessage, errors || 'Не удалось сохранить новость.');
    }
  });

  newsList?.addEventListener('click', async (event) => {
    const button = event.target.closest('button[data-action]');
    if (!button) return;

    const id = button.dataset.id;
    const item = newsItems.find((newsItem) => newsItem.id === id);
    if (!id || !item) return;

    if (button.dataset.action === 'edit') {
      fillForm(item);
      return;
    }

    if (button.dataset.action === 'delete') {
      const confirmed = window.confirm(`Удалить новость "${item.title}"?`);
      if (!confirmed) return;

      try {
        setMessage(adminMessage, 'Удаляем...', 'success');
        await requestJson(`/api/admin/news/${encodeURIComponent(id)}`, {
          method: 'DELETE',
        });
        await loadNews();
        setMessage(adminMessage, 'Новость удалена.', 'success');
      } catch {
        setMessage(adminMessage, 'Не удалось удалить новость.');
      }
    }
  });

  newButton?.addEventListener('click', resetForm);
  cancelButton?.addEventListener('click', resetForm);

  uploadButton?.addEventListener('click', () => uploadInput?.click());
  uploadInput?.addEventListener('change', () => uploadFiles(uploadInput.files));

  ['dragenter', 'dragover'].forEach((eventName) => {
    uploadZone?.addEventListener(eventName, (event) => {
      event.preventDefault();
      uploadZone.classList.add('is-dragover');
    });
  });

  ['dragleave', 'drop'].forEach((eventName) => {
    uploadZone?.addEventListener(eventName, (event) => {
      event.preventDefault();
      uploadZone.classList.remove('is-dragover');
    });
  });

  uploadZone?.addEventListener('drop', (event) => {
    uploadFiles(event.dataTransfer?.files);
  });

  uploadPreview?.addEventListener('click', (event) => {
    const button = event.target.closest('[data-remove-image]');
    if (!button) return;

    const index = Number(button.dataset.removeImage);
    if (!Number.isInteger(index)) return;

    setSelectedImages(selectedImages.filter((_, imageIndex) => imageIndex !== index));
  });

  logoutButton?.addEventListener('click', async () => {
    await requestJson('/api/admin/logout', { method: 'POST' }).catch(() => null);
    window.location.reload();
  });

  resetForm();
  loadSettings();
  loadNews();
</script>
