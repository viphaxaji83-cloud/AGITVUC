---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import { formatNewsDate, getNewsImages, getNewsParagraphs } from '../../lib/news';
import { getPublishedNewsBySlug } from '../../lib/server/newsStore';

export const prerender = false;

const newsItem = await getPublishedNewsBySlug(Astro.params.slug ?? '');
if (!newsItem) {
  Astro.response.status = 404;
}
const pageTitle = newsItem?.title ?? 'Новость не найдена';
const pageDescription =
  newsItem?.excerpt ?? 'Запрошенная новость не найдена в списке опубликованных материалов.';
const newsImages = newsItem ? getNewsImages(newsItem) : [];
const hasMultipleImages = newsImages.length > 1;
---

<BaseLayout title={pageTitle} description={pageDescription} noindex={!newsItem}>
  <Header />
  <main id="main" class="flex-1">
    <section class="news-detail section anchor-offset">
      <Container class="!max-w-[1120px]">
        {
          newsItem ? (
            <article class="news-detail__article">
              <div class="news-detail__back">
                <Button href="/news" variant="secondary">
                  <Icon name="arrow-right" size={18} />
                  Назад ко всем новостям
                </Button>
              </div>

              <div
                class:list={[
                  'news-detail__media',
                  hasMultipleImages && 'news-detail__media--carousel',
                ]}
                data-news-carousel={hasMultipleImages ? 'true' : undefined}
                tabindex={hasMultipleImages ? '0' : undefined}
                aria-label={hasMultipleImages ? 'Изображения новости' : undefined}
              >
                {newsImages.map((image, index) => (
                  <figure
                    class:list={[
                      'news-detail__slide',
                      index === 0 && 'is-active',
                    ]}
                    data-news-slide
                    aria-hidden={index === 0 ? 'false' : 'true'}
                  >
                    <img
                      src={image.src}
                      alt={image.alt}
                      loading={index === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  </figure>
                ))}

                {hasMultipleImages && (
                  <>
                    <button
                      class="news-detail__slider-button news-detail__slider-button--prev"
                      type="button"
                      data-news-prev
                      aria-label="Предыдущее изображение"
                    >
                      <Icon name="arrow-right" size={20} />
                    </button>
                    <button
                      class="news-detail__slider-button news-detail__slider-button--next"
                      type="button"
                      data-news-next
                      aria-label="Следующее изображение"
                    >
                      <Icon name="arrow-right" size={20} />
                    </button>

                    <div class="news-detail__slider-dots" aria-label="Выбор изображения">
                      {newsImages.map((_, index) => (
                        <button
                          class:list={[
                            'news-detail__slider-dot',
                            index === 0 && 'is-active',
                          ]}
                          type="button"
                          data-news-dot={index}
                          aria-label={`Показать изображение ${index + 1}`}
                          aria-current={index === 0 ? 'true' : 'false'}
                        />
                      ))}
                    </div>
                  </>
                )}
              </div>

              <div class="news-detail__content">
                <time class="news-detail__date" datetime={newsItem.date}>
                  {formatNewsDate(newsItem.date)}
                </time>
                <h1>{newsItem.title}</h1>
                <div class="news-detail__text">
                  {getNewsParagraphs(newsItem.content).map((paragraph) => <p>{paragraph}</p>)}
                </div>
              </div>
            </article>
          ) : (
            <div class="news-detail__empty">
              <h1>Новость не найдена</h1>
              <p>
                Возможно, материал был удален или ссылка была введена с ошибкой.
              </p>
              <Button href="/news" size="lg">
                Вернуться ко всем новостям
                <Icon name="arrow-right" size={20} />
              </Button>
            </div>
          )
        }
      </Container>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .news-detail {
    min-height: calc(100svh - 4rem);
  }

  .news-detail__article {
    display: grid;
    gap: clamp(22px, 3vw, 34px);
  }

  .news-detail__back {
    width: max-content;
  }

  .news-detail__back :global(svg) {
    transform: rotate(180deg);
  }

  .news-detail__media {
    position: relative;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    border: 1px solid rgb(15 23 42 / 0.14);
    border-radius: 8px;
    background: #e2e8f0;
    box-shadow: 0 24px 60px rgb(15 23 42 / 0.08);
  }

  .news-detail__media--carousel {
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }

  .news-detail__media--carousel:active {
    cursor: grabbing;
  }

  .news-detail__slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    transform: scale(1.012);
    transition:
      opacity 260ms ease,
      transform 420ms ease,
      visibility 260ms ease;
    visibility: hidden;
  }

  .news-detail__slide.is-active {
    opacity: 1;
    transform: scale(1);
    visibility: visible;
  }

  .news-detail__slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }

  .news-detail__slider-button {
    position: absolute;
    z-index: 2;
    top: 50%;
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(255 255 255 / 0.55);
    border-radius: 999px;
    background: rgb(255 255 255 / 0.72);
    color: #004329;
    cursor: pointer;
    opacity: 0.82;
    transform: translateY(-50%);
    transition:
      background-color 180ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .news-detail__slider-button:hover {
    background: #fff;
    opacity: 1;
  }

  .news-detail__slider-button--prev {
    left: 18px;
  }

  .news-detail__slider-button--prev :global(svg) {
    transform: rotate(180deg);
  }

  .news-detail__slider-button--next {
    right: 18px;
  }

  .news-detail__slider-dots {
    position: absolute;
    z-index: 2;
    right: 18px;
    bottom: 16px;
    left: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    pointer-events: none;
  }

  .news-detail__slider-dot {
    width: 9px;
    height: 9px;
    border: 0;
    border-radius: 999px;
    background: rgb(255 255 255 / 0.7);
    cursor: pointer;
    padding: 0;
    pointer-events: auto;
    transition:
      background-color 180ms ease,
      transform 180ms ease,
      width 180ms ease;
  }

  .news-detail__slider-dot.is-active {
    width: 24px;
    background: #004329;
  }

  .news-detail__content {
    max-width: none;
  }

  .news-detail__date {
    display: inline-flex;
    margin-bottom: 14px;
    color: #b80008;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .news-detail__content h1,
  .news-detail__empty h1 {
    margin: 0;
    color: #004329;
    max-width: 100%;
    font-size: clamp(1.65rem, 2.25vw, 2.55rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.06;
    text-transform: uppercase;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .news-detail__text {
    display: grid;
    width: 100%;
    max-width: 100%;
    gap: 16px;
    margin-top: 24px;
    color: rgb(15 23 42 / 0.72);
    font-size: clamp(1rem, 1.08vw, 1.08rem);
    line-height: 1.68;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .news-detail__text p {
    margin: 0;
  }

  .news-detail__empty {
    display: grid;
    max-width: 680px;
    gap: 18px;
  }

  .news-detail__empty p {
    margin: 0;
    color: rgb(15 23 42 / 0.72);
    font-size: 1.05rem;
    line-height: 1.58;
  }

  :global(html[data-theme='dark']) .news-detail__media {
    border-color: rgb(148 163 184 / 0.22);
    box-shadow: 0 24px 64px rgb(0 0 0 / 0.28);
  }

  :global(html[data-theme='dark']) .news-detail__slider-button {
    border-color: rgb(148 163 184 / 0.3);
    background: rgb(15 23 42 / 0.68);
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .news-detail__slider-button:hover {
    background: rgb(15 23 42 / 0.9);
  }

  :global(html[data-theme='dark']) .news-detail__slider-dot {
    background: rgb(226 232 240 / 0.68);
  }

  :global(html[data-theme='dark']) .news-detail__slider-dot.is-active {
    background: #93c5fd;
  }

  :global(html[data-theme='dark']) .news-detail__date {
    color: #93c5fd;
  }

  :global(html[data-theme='dark']) .news-detail__content h1,
  :global(html[data-theme='dark']) .news-detail__empty h1 {
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .news-detail__text,
  :global(html[data-theme='dark']) .news-detail__empty p {
    color: rgb(226 232 240 / 0.82);
  }

  @media (max-width: 640px) {
    .news-detail__media {
      aspect-ratio: 4 / 3;
    }

    .news-detail__slider-button {
      width: 36px;
      height: 36px;
    }

    .news-detail__slider-button--prev {
      left: 10px;
    }

    .news-detail__slider-button--next {
      right: 10px;
    }

    .news-detail__content h1,
    .news-detail__empty h1 {
      font-size: clamp(1.55rem, 7vw, 2rem);
    }
  }
</style>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-news-carousel]');

  carousels.forEach((carousel) => {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLElement>('[data-news-slide]'),
    );
    const dots = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>('[data-news-dot]'),
    );
    let activeIndex = 0;
    let pointerStartX = 0;
    let pointerStartY = 0;
    let isPointerDown = false;
    const controlSelector = '[data-news-prev], [data-news-next], [data-news-dot]';

    const setActive = (nextIndex: number) => {
      if (slides.length === 0) return;

      activeIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;

        slide.classList.toggle('is-active', isActive);
        slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });

      dots.forEach((dot, index) => {
        const isActive = index === activeIndex;

        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const showPrevious = () => setActive(activeIndex - 1);
    const showNext = () => setActive(activeIndex + 1);

    carousel.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const control = target?.closest<HTMLElement>(controlSelector);

      if (!control || !carousel.contains(control)) return;

      event.preventDefault();
      event.stopPropagation();

      if (control.matches('[data-news-prev]')) {
        showPrevious();
        return;
      }

      if (control.matches('[data-news-next]')) {
        showNext();
        return;
      }

      if (control.matches('[data-news-dot]')) {
        setActive(Number(control.dataset.newsDot ?? 0));
      }
    });

    carousel.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') showPrevious();
      if (event.key === 'ArrowRight') showNext();
    });

    carousel.addEventListener('pointerdown', (event) => {
      const target = event.target as HTMLElement | null;

      if (target?.closest(controlSelector)) return;

      isPointerDown = true;
      pointerStartX = event.clientX;
      pointerStartY = event.clientY;
      carousel.setPointerCapture(event.pointerId);
    });

    carousel.addEventListener('pointerup', (event) => {
      if (!isPointerDown) return;

      isPointerDown = false;
      const deltaX = event.clientX - pointerStartX;
      const deltaY = event.clientY - pointerStartY;

      if (Math.abs(deltaX) < 48 || Math.abs(deltaX) < Math.abs(deltaY)) return;

      if (deltaX > 0) {
        showPrevious();
      } else {
        showNext();
      }
    });

    carousel.addEventListener('pointercancel', () => {
      isPointerDown = false;
    });
  });
</script>
