---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Container from '../../components/ui/Container.astro';
import Button from '../../components/ui/Button.astro';
import Icon from '../../components/ui/Icon.astro';
import NewsCard from '../../components/news/NewsCard.astro';
import { news } from '../../data/news';
---

<BaseLayout
  title="Все новости"
  description="Все новости и объявления контрактной службы для студентов МГТУ."
>
  <Header />
  <main id="main" class="flex-1">
    <section class="news-page section anchor-offset">
      <Container class="!max-w-[1320px]">
        <div class="news-page__header">
          <div>
            <h1>Все новости</h1>
          </div>

          <Button href="/#news" variant="secondary">
            На главную
            <Icon name="arrow-right" size={18} />
          </Button>
        </div>

        <div class="news-page__scroll" aria-label="Список всех новостей">
          <div class="news-page__grid">
            {
              news.map((item, index) => (
                <NewsCard news={item} priority={index < 3} />
              ))
            }
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .news-page {
    min-height: calc(100svh - 4rem);
  }

  .news-page__header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: clamp(24px, 3vw, 38px);
  }

  .news-page__header h1 {
    margin: 0;
    color: #004329;
    font-size: clamp(2.7rem, 6vw, 6.2rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
    text-transform: uppercase;
  }

  .news-page__scroll {
    max-height: min(1120px, calc(100svh - 190px));
    overflow-y: auto;
    padding-right: 6px;
    scrollbar-color: rgb(0 67 41 / 0.34) transparent;
  }

  .news-page__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(16px, 2vw, 24px);
    padding-bottom: 4px;
  }

  :global(html[data-theme='dark']) .news-page__header h1 {
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .news-page__scroll {
    scrollbar-color: rgb(147 197 253 / 0.38) transparent;
  }

  @media (max-width: 900px) {
    .news-page__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .news-page__header {
      align-items: stretch;
      flex-direction: column;
    }

    .news-page__header h1 {
      font-size: clamp(2.4rem, 15vw, 3.8rem);
    }

    .news-page__scroll {
      max-height: none;
      overflow: visible;
      padding-right: 0;
    }

    .news-page__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
