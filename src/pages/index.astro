---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import VideoHeroBlock from '../components/VideoHeroBlock.astro';
import EducationBlock from '../components/EducationBlock.astro';
import ConsultationCta from '../components/ConsultationCta.astro';
import FinanceBlock from '../components/FinanceBlock.astro';
import NewsSection from '../components/NewsSection.astro';
import ContactForm from '../components/ContactForm.astro';
import PartnersTicker from '../components/PartnersTicker.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <PartnersTicker />
    <Benefits />
    <EducationBlock />
    <ConsultationCta />
    <FinanceBlock />
    <ConsultationCta />
    <VideoHeroBlock />
    <NewsSection />
    <ContactForm />
  </main>
  <Footer />
</BaseLayout>
