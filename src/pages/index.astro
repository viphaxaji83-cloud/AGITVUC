---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import EducationBlock from '../components/EducationBlock.astro';
import FinanceBlock from '../components/FinanceBlock.astro';
import SupportBlock from '../components/SupportBlock.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <Benefits />
    <EducationBlock />
    <FinanceBlock />
    <SupportBlock />
    <ProcessSteps />
    <FAQ />
    <ContactForm />
  </main>
  <Footer />
</BaseLayout>

<script>
  (() => {
    const main = document.getElementById('main');
    if (!main) return;

    const sectionSelector = ':scope > section[id]';
    let sections = Array.from(
      main.querySelectorAll<HTMLElement>(sectionSelector),
    );
    let animationFrame: number | undefined;
    let unlockTimer: number | undefined;
    let isSectionJumping = false;
    let wheelCooldownUntil = 0;
    let isTouchScrollIgnored = false;
    let touchStartY: number | undefined;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const refreshSections = () => {
      sections = Array.from(
        main.querySelectorAll<HTMLElement>(sectionSelector),
      );
    };

    const getHeaderOffset = () =>
      document.querySelector('header')?.getBoundingClientRect().height ?? 0;

    const clampScrollTop = (targetTop: number) => {
      const maxScrollTop = Math.max(
        0,
        document.documentElement.scrollHeight - window.innerHeight,
      );

      return Math.min(Math.max(targetTop, 0), maxScrollTop);
    };

    const getSectionScrollTarget = (section: HTMLElement) => {
      const sectionTop = section.getBoundingClientRect().top + window.scrollY;
      const visibleCenter = (getHeaderOffset() + window.innerHeight) / 2;

      return clampScrollTop(
        sectionTop + section.offsetHeight / 2 - visibleCenter,
      );
    };

    const shouldIgnoreScrollTarget = (target: EventTarget | null) => {
      if (!(target instanceof HTMLElement)) return false;
      return Boolean(
        target.closest('input, textarea, select, [contenteditable]'),
      );
    };

    const shouldIgnoreKeyboardTarget = (target: EventTarget | null) => {
      if (!(target instanceof HTMLElement)) return false;
      return Boolean(
        target.closest('input, textarea, select, button, [contenteditable]'),
      );
    };

    const getCurrentSectionIndex = () => {
      const anchorY =
        window.scrollY + (getHeaderOffset() + window.innerHeight) / 2;
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      sections.forEach((section, index) => {
        const top = section.getBoundingClientRect().top + window.scrollY;
        const sectionCenter = top + section.offsetHeight / 2;
        const distance = Math.abs(anchorY - sectionCenter);
        if (distance < closestDistance) {
          closestIndex = index;
          closestDistance = distance;
        }
      });

      return closestIndex;
    };

    const canSnapFromSection = (index: number, direction: 1 | -1) => {
      if (direction > 0 && index >= sections.length - 1) return false;
      if (direction < 0 && index <= 0) return false;
      return Boolean(sections[index]);
    };

    const finishJump = () => {
      if (animationFrame) window.cancelAnimationFrame(animationFrame);
      if (unlockTimer) window.clearTimeout(unlockTimer);
      animationFrame = undefined;
      unlockTimer = undefined;
      isSectionJumping = false;
      wheelCooldownUntil = performance.now() + 120;
      document.documentElement.classList.remove('is-instant-page-jump');
    };

    const animateTo = (targetTop: number) => {
      if (animationFrame) window.cancelAnimationFrame(animationFrame);
      if (unlockTimer) window.clearTimeout(unlockTimer);

      const startY = window.scrollY;
      const distance = targetTop - startY;
      if (Math.abs(distance) < 4) {
        finishJump();
        return;
      }

      isSectionJumping = true;
      document.documentElement.classList.add('is-instant-page-jump');

      if (reduceMotion.matches) {
        window.scrollTo(0, targetTop);
        finishJump();
        return;
      }

      const duration = Math.min(420, Math.max(260, Math.abs(distance) * 0.2));
      const startedAt = performance.now();
      const easeOutCubic = (progress: number) =>
        1 - Math.pow(1 - progress, 3);

      const step = (now: number) => {
        const progress = Math.min((now - startedAt) / duration, 1);
        window.scrollTo(0, startY + distance * easeOutCubic(progress));

        if (progress < 1) {
          animationFrame = window.requestAnimationFrame(step);
          return;
        }

        finishJump();
      };

      animationFrame = window.requestAnimationFrame(step);
      unlockTimer = window.setTimeout(finishJump, duration + 140);
    };

    const jumpByDirection = (direction: 1 | -1) => {
      refreshSections();
      const currentIndex = getCurrentSectionIndex();
      if (!canSnapFromSection(currentIndex, direction)) return false;

      const nextSection = sections[currentIndex + direction];
      if (!nextSection) return false;

      animateTo(getSectionScrollTarget(nextSection));
      return true;
    };

    const getSectionFromAnchorTarget = (target: HTMLElement) => {
      const section = target.matches('section[id]')
        ? target
        : target.closest<HTMLElement>('section[id]');

      if (!section || section.parentElement !== main) return undefined;
      return section;
    };

    window.addEventListener(
      'wheel',
      (event) => {
        if (shouldIgnoreScrollTarget(event.target)) return;
        if (Math.abs(event.deltaY) < 10) return;

        if (isSectionJumping || performance.now() < wheelCooldownUntil) {
          event.preventDefault();
          return;
        }

        const direction = event.deltaY > 0 ? 1 : -1;
        if (jumpByDirection(direction)) {
          event.preventDefault();
        }
      },
      { passive: false },
    );

    window.addEventListener(
      'touchstart',
      (event) => {
        isTouchScrollIgnored = shouldIgnoreScrollTarget(event.target);
        if (isTouchScrollIgnored) {
          touchStartY = undefined;
          return;
        }

        touchStartY = event.touches[0]?.clientY;
      },
      { passive: true },
    );

    window.addEventListener(
      'touchmove',
      (event) => {
        if (isTouchScrollIgnored) return;
        if (touchStartY === undefined) return;

        const currentY = event.touches[0]?.clientY;
        if (currentY === undefined) return;

        const deltaY = touchStartY - currentY;
        if (Math.abs(deltaY) < 46) return;

        if (isSectionJumping) {
          event.preventDefault();
          return;
        }

        const direction = deltaY > 0 ? 1 : -1;
        if (jumpByDirection(direction)) {
          event.preventDefault();
          touchStartY = undefined;
        }
      },
      { passive: false },
    );

    window.addEventListener('touchend', () => {
      touchStartY = undefined;
      isTouchScrollIgnored = false;
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;

      const link = event.target.closest<HTMLAnchorElement>('a[href^="#"]');
      const hash = link?.hash;
      if (!hash) return;

      let anchorTarget: HTMLElement | null = null;
      try {
        anchorTarget = document.getElementById(
          decodeURIComponent(hash.slice(1)),
        );
      } catch {
        return;
      }

      if (!anchorTarget) return;
      refreshSections();

      const section = getSectionFromAnchorTarget(anchorTarget);
      if (!section || !sections.includes(section)) return;

      event.preventDefault();
      history.pushState(null, '', hash);
      animateTo(getSectionScrollTarget(section));
    });

    document.addEventListener('keydown', (event) => {
      const isForwardScrollKey =
        event.code === 'ArrowDown' ||
        event.code === 'PageDown' ||
        (event.code === 'Space' && !event.shiftKey);

      const isBackwardScrollKey =
        event.code === 'ArrowUp' ||
        event.code === 'PageUp' ||
        (event.code === 'Space' && event.shiftKey);

      if (
        event.altKey ||
        event.ctrlKey ||
        event.metaKey ||
        shouldIgnoreKeyboardTarget(event.target)
      ) {
        return;
      }

      if (isForwardScrollKey && jumpByDirection(1)) {
        event.preventDefault();
        return;
      }

      if (isBackwardScrollKey && jumpByDirection(-1)) {
        event.preventDefault();
      }
    });

    window.addEventListener('resize', refreshSections);
  })();
</script>
