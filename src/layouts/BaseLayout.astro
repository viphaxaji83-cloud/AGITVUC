---
import '../styles/global.css';
import { site } from '../data/site';
import ScrollTopButton from '../components/ScrollTopButton.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  bodyClass?: string;
  forceTheme?: 'light' | 'dark';
}

const {
  title,
  description = site.description,
  ogImage = '/og-image.svg',
  canonical,
  noindex = false,
  bodyClass = '',
  forceTheme,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.shortName}` : site.ogTitle;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://example.university').toString();
const shouldLoadJivo = !noindex;
---

<!doctype html>
<html lang="ru" data-theme="light" data-force-theme={forceTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <script is:inline>
      (() => {
        const storageKey = 'agitvuc-theme';
        const root = document.documentElement;
        const forcedTheme = root.dataset.forceTheme;
        const stored = localStorage.getItem(storageKey);
        const theme = forcedTheme === 'dark' || forcedTheme === 'light'
          ? forcedTheme
          : stored === 'dark' || stored === 'light'
          ? stored
          : 'light';

        root.dataset.theme = theme;
        root.style.colorScheme = theme;
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}

    <link rel="icon" href="/favicon/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="theme-color" content="#1d4ed8" data-theme-color />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.shortName} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="format-detection" content="telephone=no" />
  </head>

  <body class:list={['min-h-screen flex flex-col', bodyClass]}>
    <a href="#main" class="skip-link">Перейти к основному содержимому</a>
    <slot />
    <ScrollTopButton />
    {shouldLoadJivo && <script is:inline src="https://code.jivo.ru/widget/H1IFYUa679" async></script>}
  </body>
</html>
