---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
import Icon from './ui/Icon.astro';
import { site } from '../data/site';
---

<header class="sticky top-0 z-40 border-b border-ink-200/70 bg-white/85 backdrop-blur-md">
  <Container class="flex h-16 items-center justify-between gap-3">
    <a
      href="/"
      class="site-logo site-logo--header group"
      aria-label={`${site.shortName} — на главную`}
    >
      <img
        class="site-logo__image site-logo__image--light"
        src="/logos/logo_short_black.png"
        alt=""
        width="1058"
        height="411"
        loading="eager"
        decoding="async"
      />
      <img
        class="site-logo__image site-logo__image--dark"
        src="/logos/logo_short_white.png"
        alt=""
        width="1058"
        height="410"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav
      class="ml-auto hidden lg:flex items-center gap-0.5"
      aria-label="Основная навигация"
    >
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="whitespace-nowrap rounded-lg px-2.5 py-2 text-sm font-medium text-ink-700 hover:text-brand-800 hover:bg-brand-50 transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:flex items-center gap-2">
      <Button href="#contacts" variant="primary" size="sm" class="whitespace-nowrap">
        Получить консультацию
      </Button>
      <button
        type="button"
        class="theme-toggle theme-toggle--compact"
        data-theme-toggle
        aria-pressed="false"
        aria-label="Включить темную тему"
        title="Переключить тему"
      >
        <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
          <Icon name="moon" size={18} />
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
          <Icon name="sun" size={18} />
        </span>
      </button>
    </div>

    <div class="flex items-center gap-2 lg:hidden">
    <button
      type="button"
      class="theme-toggle theme-toggle--compact"
      data-theme-toggle
      aria-pressed="false"
      aria-label="Включить темную тему"
      title="Переключить тему"
    >
      <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
        <Icon name="moon" size={18} />
      </span>
      <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
        <Icon name="sun" size={18} />
      </span>
      <span class="sr-only" data-theme-label>Темная тема</span>
    </button>

    <button
      type="button"
      id="menu-toggle"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-ink-200 text-ink-700 hover:bg-ink-50"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Открыть меню"
    >
      <span data-icon="open"><Icon name="menu" /></span>
      <span data-icon="close" class="hidden"><Icon name="close" /></span>
    </button>
    </div>
  </Container>

  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-ink-200 bg-white"
    role="dialog"
    aria-modal="false"
    aria-label="Мобильное меню"
  >
    <Container class="py-4">
      <nav aria-label="Мобильная навигация" class="flex flex-col gap-1">
        {
          site.nav.map((item) => (
            <a
              href={item.href}
              class="rounded-lg px-3 py-3 text-base font-medium text-ink-800 hover:bg-brand-50 hover:text-brand-800"
              data-mobile-link
            >
              {item.label}
            </a>
          ))
        }
      </nav>
      <div class="mt-4">
        <Button href="#contacts" variant="primary" fullWidth>
          Получить консультацию
        </Button>
      </div>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = toggle?.querySelector('[data-icon="open"]');
  const closeIcon = toggle?.querySelector('[data-icon="close"]');

  const setOpen = (open: boolean) => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute(
      'aria-label',
      open ? 'Закрыть меню' : 'Открыть меню',
    );
    menu.classList.toggle('hidden', !open);
    openIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  };

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!expanded);
  });

  menu
    ?.querySelectorAll<HTMLAnchorElement>('[data-mobile-link]')
    .forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setOpen(false);
  });

  const themeStorageKey = 'agitvuc-theme';
  const themeButtons = document.querySelectorAll<HTMLButtonElement>(
    '[data-theme-toggle]',
  );
  const themeColor = document.querySelector<HTMLMetaElement>(
    'meta[data-theme-color]',
  );

  const getCurrentTheme = () =>
    document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';

  const setTheme = (theme: 'light' | 'dark') => {
    const isDark = theme === 'dark';
    document.documentElement.dataset.theme = theme;
    document.documentElement.style.colorScheme = theme;
    localStorage.setItem(themeStorageKey, theme);
    themeColor?.setAttribute('content', isDark ? '#020617' : '#1d4ed8');

    themeButtons.forEach((button) => {
      button.setAttribute('aria-pressed', String(isDark));
      button.setAttribute(
        'aria-label',
        isDark ? 'Включить светлую тему' : 'Включить темную тему',
      );
      button
        .querySelectorAll<HTMLElement>('[data-theme-label]')
        .forEach((label) => {
          label.textContent = isDark ? 'Светлая тема' : 'Темная тема';
        });
    });
  };

  setTheme(getCurrentTheme());

  themeButtons.forEach((button) => {
    button.addEventListener('click', () => {
      setTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
    });
  });
</script>
