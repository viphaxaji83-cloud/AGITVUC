---
import Container from './ui/Container.astro';

const slides = [
  {
    eyebrow: 'Общие выплаты',
    title: 'По официальным документам',
    tone: 'red',
  },
  {
    eyebrow: 'Специальный контракт',
    title: 'Условия и срок обсуждаются на консультации',
    tone: 'blue',
  },
  {
    eyebrow: 'Направления БПЛА',
    title: 'Операторские и технические роли',
    tone: 'red',
  },
  {
    eyebrow: 'Обучение',
    title: 'Индивидуальная образовательная траектория',
    tone: 'blue',
  },
  {
    eyebrow: 'Поддержка',
    title: 'Сопровождение университета',
    tone: 'red',
  },
];
---

<section id="benefits" class="benefits-slider anchor-offset">
  <span id="directions" class="benefits-anchor anchor-offset" aria-hidden="true"></span>
  <Container class="!max-w-[1760px]">
    <div class="benefits-layout">
      <div class="benefits-carousel-shell" data-benefits-carousel>
        <button
          type="button"
          class="benefits-nav benefits-nav--prev"
          aria-label="Предыдущая карточка"
          data-benefits-prev
        >
        </button>

        <div
          class="benefits-carousel"
          aria-label="Ключевые условия и преимущества"
        >
          <div class="benefits-stack" aria-live="polite">
            {
              slides.map((slide, index) => (
                <button
                  type="button"
                  class:list={[
                    'benefit-slide',
                    slide.tone === 'blue'
                      ? 'benefit-slide--blue'
                      : 'benefit-slide--red',
                  ]}
                  data-benefit-slide
                  data-slide-index={index}
                  data-position={index === 0 ? 'active' : `after-${index}`}
                  aria-current={index === 0 ? 'true' : 'false'}
                  aria-label={`Показать карточку: ${slide.eyebrow}`}
                >
                  <span class="benefit-slide__number" aria-hidden="true">
                    {index + 1}
                  </span>
                  <span class="benefit-slide__eyebrow">{slide.eyebrow}</span>
                  <span class="benefit-slide__title">{slide.title}</span>
                </button>
              ))
            }
          </div>
        </div>

        <button
          type="button"
          class="benefits-nav benefits-nav--next"
          aria-label="Следующая карточка"
          data-benefits-next
        >
        </button>
      </div>

      <div class="benefits-statement">
        <p class="benefits-statement__text">
          Сегодня в России формируется новый род войск — подразделения
          беспилотных авиационных систем. Это направление уже сейчас играет
          ключевую роль в обеспечении безопасности страны и открывает новые
          профессиональные возможности, в том числе для молодежи с техническим
          образованием.
        </p>
        <a
          href="#contacts"
          class="benefits-statement__text benefits-statement__text--separate"
        >
          Если ты интересуешься современными технологиями и готов служить
          Родине, в Адыгее продолжается набор в войска беспилотных систем.
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
  .benefits-slider {
    position: relative;
    display: grid;
    min-height: calc(100svh - 4rem);
    align-items: center;
    overflow: hidden;
    background: #fbfcff;
    padding-block: clamp(50px, 5.6vw, 92px);
  }

  .benefits-slider::before,
  .benefits-slider::after {
    position: absolute;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .benefits-slider::before {
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      linear-gradient(0deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      repeating-linear-gradient(
        132deg,
        transparent 0 138px,
        rgb(29 78 216 / 0.105) 139px 140px,
        transparent 141px 280px
      );
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    opacity: 0.92;
  }

  .benefits-slider::after {
    inset: clamp(34px, 5vw, 84px) clamp(20px, 5vw, 92px);
    background:
      linear-gradient(rgb(15 23 42 / 0.14), rgb(15 23 42 / 0.14)) left top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) left top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        1px 148px no-repeat;
    opacity: 0.82;
  }

  .benefits-slider.anchor-offset,
  .benefits-anchor.anchor-offset {
    scroll-margin-top: 4rem;
  }

  .benefits-anchor {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }

  .benefits-layout {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    flex-direction: column;
    justify-content: center;
    gap: clamp(38px, 5vw, 72px);
  }

  .benefits-carousel-shell {
    position: relative;
    width: 100vw;
    margin-inline: calc(50% - 50vw);
  }

  .benefits-nav {
    position: absolute;
    top: 50%;
    z-index: 30;
    display: flex;
    width: clamp(30px, 2.6vw, 44px);
    height: clamp(38px, 3vw, 52px);
    align-items: center;
    justify-content: center;
    border: 0;
    background: transparent;
    color: rgb(71 85 105 / 0.45);
    cursor: pointer;
    transform: translateY(-50%);
    transition:
      color 180ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .benefits-nav::before {
    display: block;
    width: clamp(22px, 1.9vw, 34px);
    height: clamp(22px, 1.9vw, 34px);
    border-block-start: clamp(2px, 0.16vw, 3px) solid currentColor;
    border-inline-end: clamp(2px, 0.16vw, 3px) solid currentColor;
    content: '';
  }

  .benefits-nav--prev {
    left: clamp(16px, 4vw, 72px);
  }

  .benefits-nav--prev::before {
    transform: rotate(-135deg);
  }

  .benefits-nav--next {
    right: clamp(16px, 4vw, 72px);
  }

  .benefits-nav--next::before {
    transform: rotate(45deg);
  }

  .benefits-nav:hover {
    color: rgb(51 65 85 / 0.72);
    transform: translateY(-50%) scale(1.04);
  }

  .benefits-nav:active {
    color: rgb(30 41 59 / 0.78);
    transform: translateY(-50%) scale(0.98);
  }

  .benefits-carousel {
    position: relative;
    margin-inline: auto;
    height: 350px;
    max-width: 1280px;
    perspective: 1200px;
  }

  .benefits-stack {
    position: absolute;
    inset: 0;
    overflow: visible;
    touch-action: pan-y;
    transform-style: preserve-3d;
    user-select: none;
  }

  .benefit-slide {
    position: absolute;
    top: 0;
    left: 50%;
    display: flex;
    width: min(92vw, 1180px);
    height: 350px;
    flex-direction: column;
    justify-content: flex-start;
    overflow: hidden;
    border: 0;
    border-radius: 10px;
    padding: 66px 92px 34px 40px;
    box-shadow: 10px 0 10px rgb(0 0 0 / 0.25);
    color: #fff;
    cursor: grab;
    text-align: left;
    transition:
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 260ms ease,
      filter 260ms ease;
    transform-origin: center bottom;
    will-change: transform;
  }

  .benefit-slide:active {
    cursor: grabbing;
  }

  .benefit-slide::after {
    position: absolute;
    inset: 0;
    content: '';
    background: linear-gradient(
      105deg,
      transparent 28%,
      rgb(255 255 255 / 0.2) 43%,
      transparent 58%
    );
    opacity: 0;
    pointer-events: none;
    transform: translateX(-120%) skewX(-10deg);
  }

  .benefit-slide:hover {
    box-shadow: 12px 0 24px rgb(15 23 42 / 0.3);
  }

  .benefit-slide--red {
    background:
      linear-gradient(0deg, rgb(0 0 0 / 0.2), rgb(0 0 0 / 0.2)),
      linear-gradient(135deg, #c10007 0%, #e7000b 100%);
  }

  .benefit-slide--blue {
    background:
      linear-gradient(0deg, rgb(0 0 0 / 0.2), rgb(0 0 0 / 0.2)),
      linear-gradient(135deg, #155dfc 0%, #1447e6 100%);
  }

  .benefit-slide[data-position='active'] {
    z-index: 10;
    transform: translate3d(-50%, 0, 0) scale(1);
  }

  .benefits-carousel-shell.is-transitioning .benefit-slide {
    transition-duration: 760ms;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  .benefits-carousel-shell.is-transitioning
    .benefit-slide[data-position='active'] {
    box-shadow:
      14px 0 24px rgb(15 23 42 / 0.28),
      0 20px 42px rgb(15 23 42 / 0.12);
    filter: saturate(1.06) brightness(1.03);
  }

  .benefit-slide[data-motion^='enter']::after {
    animation: benefit-slide-sheen 760ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .benefit-slide[data-motion^='leave'] {
    filter: saturate(1.02);
  }

  .benefit-slide[data-position='before-1'] {
    z-index: 8;
    transform: translate3d(calc(-50% - 98px), 0, 0) scale(0.99);
  }

  .benefit-slide[data-position='before-2'] {
    z-index: 7;
    transform: translate3d(calc(-50% - 168px), 0, 0) scale(0.985);
  }

  .benefit-slide[data-position='before-3'] {
    z-index: 6;
    transform: translate3d(calc(-50% - 216px), 0, 0) scale(0.98);
  }

  .benefit-slide[data-position='before-4'] {
    z-index: 5;
    transform: translate3d(calc(-50% - 254px), 0, 0) scale(0.975);
  }

  .benefit-slide[data-position='after-1'] {
    z-index: 8;
    transform: translate3d(calc(-50% + 98px), 0, 0) scale(0.99);
  }

  .benefit-slide[data-position='after-2'] {
    z-index: 7;
    transform: translate3d(calc(-50% + 168px), 0, 0) scale(0.985);
  }

  .benefit-slide[data-position='after-3'] {
    z-index: 6;
    transform: translate3d(calc(-50% + 216px), 0, 0) scale(0.98);
  }

  .benefit-slide[data-position='after-4'] {
    z-index: 5;
    transform: translate3d(calc(-50% + 254px), 0, 0) scale(0.975);
  }

  .benefit-slide__number {
    position: absolute;
    top: 4px;
    right: 36px;
    color: rgb(255 255 255 / 0.55);
    font-size: 4.85rem;
    font-weight: 800;
    line-height: 1.2;
    backface-visibility: hidden;
    transform: translateZ(0);
  }

  .benefit-slide__eyebrow {
    display: block;
    margin: 0;
    max-width: 860px;
    color: rgb(255 255 255 / 0.8);
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1.2;
    backface-visibility: hidden;
    overflow-wrap: anywhere;
    transform: translateZ(0);
  }

  .benefit-slide__title {
    display: block;
    margin-top: 8px;
    max-width: 880px;
    color: #fff;
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.08;
    backface-visibility: hidden;
    overflow-wrap: anywhere;
    transform: translateZ(0);
  }

  .benefits-statement {
    width: min(100%, 1500px);
    margin-inline: auto;
    padding-inline: 0;
  }

  .benefits-statement__text {
    margin: 0;
    color: #004329;
    font-size: clamp(1.24rem, 1.42vw, 2.1rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.08;
    text-align: justify;
    text-align-last: center;
    text-wrap: wrap;
    word-spacing: -0.08em;
    overflow-wrap: normal;
    hyphens: manual;
  }

  .benefits-statement__text--separate {
    display: block;
    width: min(100%, 1120px);
    margin: clamp(18px, 2.2vw, 34px) auto 0;
    border: 1px solid rgb(15 23 42 / 0.16);
    border-radius: 20px;
    background: transparent;
    padding: clamp(14px, 1.5vw, 22px) clamp(18px, 2.2vw, 36px);
    color: #b80008;
    font-weight: 600;
    line-height: 1.07;
    box-shadow: 0 16px 36px rgb(15 23 42 / 0.035);
    text-align: center;
    text-align-last: center;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .benefits-statement__text--separate:hover {
    border-color: rgb(184 0 8 / 0.32);
    box-shadow: 0 20px 44px rgb(15 23 42 / 0.075);
    transform: translateY(-2px);
  }

  .benefits-statement__text--separate:active {
    transform: translateY(0);
  }

  @media (max-width: 1023px) {
    .benefits-slider {
      padding-block: 56px;
    }

    .benefits-layout {
      gap: 44px;
    }

    .benefits-nav {
      width: 42px;
      height: 64px;
      color: rgb(29 78 216 / 0.34);
    }

    .benefits-nav::before {
      width: 28px;
      height: 28px;
      border-width: 3px;
    }

    .benefits-nav--prev {
      left: 4px;
    }

    .benefits-nav--next {
      right: 4px;
    }

    .benefits-carousel {
      height: 312px;
    }

    .benefit-slide {
      width: calc(100vw - 32px);
      height: 312px;
      padding: 58px 56px 42px 24px;
    }

    .benefit-slide[data-position='before-1'] {
      transform: translate3d(calc(-50% - 18px), 0, 0) scale(0.985);
    }

    .benefit-slide[data-position='before-2'] {
      transform: translate3d(calc(-50% - 30px), 0, 0) scale(0.97);
    }

    .benefit-slide[data-position='before-3'] {
      transform: translate3d(calc(-50% - 40px), 0, 0) scale(0.955);
    }

    .benefit-slide[data-position='before-4'] {
      transform: translate3d(calc(-50% - 48px), 0, 0) scale(0.94);
    }

    .benefit-slide[data-position='after-1'] {
      transform: translate3d(calc(-50% + 18px), 0, 0) scale(0.985);
    }

    .benefit-slide[data-position='after-2'] {
      transform: translate3d(calc(-50% + 30px), 0, 0) scale(0.97);
    }

    .benefit-slide[data-position='after-3'] {
      transform: translate3d(calc(-50% + 40px), 0, 0) scale(0.955);
    }

    .benefit-slide[data-position='after-4'] {
      transform: translate3d(calc(-50% + 48px), 0, 0) scale(0.94);
    }

    .benefit-slide__number {
      top: 6px;
      right: 22px;
      font-size: 3.4rem;
    }

    .benefit-slide__eyebrow {
      font-size: 2rem;
      line-height: 1.12;
    }

    .benefit-slide__title {
      font-size: 2.75rem;
      line-height: 1.08;
    }

    .benefits-statement__text {
      font-size: clamp(1.24rem, 3.6vw, 2rem);
      line-height: 1.08;
      text-align: center;
      text-align-last: center;
      text-wrap: pretty;
    }

    .benefits-statement {
      padding-inline: 0;
    }
  }

  @media (max-width: 767px) {
    .benefits-slider {
      min-height: calc(100svh - 4rem);
      padding-block: 44px;
    }

    .benefits-layout {
      gap: 36px;
    }

    .benefits-nav {
      display: none;
    }
  }

  @media (min-width: 1024px) and (max-width: 1279px) {
    .benefit-slide__eyebrow {
      font-size: 2.25rem;
    }

    .benefit-slide__title {
      font-size: 3.1rem;
    }
  }

  @media (min-width: 1024px) and (max-width: 1599px) {
    .benefit-slide {
      width: min(76vw, 1080px);
    }

    .benefit-slide[data-position='before-1'] {
      transform: translate3d(calc(-50% - 54px), 0, 0) scale(0.99);
    }

    .benefit-slide[data-position='before-2'] {
      transform: translate3d(calc(-50% - 92px), 0, 0) scale(0.985);
    }

    .benefit-slide[data-position='before-3'] {
      transform: translate3d(calc(-50% - 124px), 0, 0) scale(0.98);
    }

    .benefit-slide[data-position='before-4'] {
      transform: translate3d(calc(-50% - 150px), 0, 0) scale(0.975);
    }

    .benefit-slide[data-position='after-1'] {
      transform: translate3d(calc(-50% + 54px), 0, 0) scale(0.99);
    }

    .benefit-slide[data-position='after-2'] {
      transform: translate3d(calc(-50% + 92px), 0, 0) scale(0.985);
    }

    .benefit-slide[data-position='after-3'] {
      transform: translate3d(calc(-50% + 124px), 0, 0) scale(0.98);
    }

    .benefit-slide[data-position='after-4'] {
      transform: translate3d(calc(-50% + 150px), 0, 0) scale(0.975);
    }
  }

  @media (max-width: 520px) {
    .benefits-carousel,
    .benefit-slide {
      height: 286px;
    }

    .benefit-slide {
      padding: 52px 44px 34px 22px;
    }

    .benefit-slide__eyebrow {
      font-size: 1.5rem;
    }

    .benefit-slide__title {
      font-size: 2.05rem;
    }

    .benefits-statement__text {
      font-size: clamp(1.13rem, 5.1vw, 1.52rem);
      line-height: 1.24;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .benefit-slide {
      transition: none;
    }
  }

  @keyframes benefit-slide-sheen {
    0% {
      opacity: 0;
      transform: translateX(-120%) skewX(-10deg);
    }

    24% {
      opacity: 1;
    }

    100% {
      opacity: 0;
      transform: translateX(120%) skewX(-10deg);
    }
  }
</style>

<script>
  const carousel = document.querySelector<HTMLElement>(
    '[data-benefits-carousel]',
  );

  if (carousel) {
    const slides = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>('[data-benefit-slide]'),
    );
    const prev = carousel.querySelector<HTMLButtonElement>('[data-benefits-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-benefits-next]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const intervalMs = 10000;
    let activeIndex = 0;
    let didSwipe = false;
    let pointerStartX: number | undefined;
    let timer: number | undefined;
    let scrollResumeTimer: number | undefined;
    let transitionCleanup: number | undefined;

    const clamp = (index: number) =>
      Math.min(Math.max(index, 0), slides.length - 1);

    const normalize = (index: number) =>
      (index + slides.length) % slides.length;

    const getPosition = (index: number) => {
      const distance = index - activeIndex;
      if (distance === 0) return 'active';
      return distance < 0 ? `before-${Math.abs(distance)}` : `after-${distance}`;
    };

    const render = () => {
      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.dataset.position = getPosition(index);
        slide.setAttribute('aria-current', isActive ? 'true' : 'false');
        slide.tabIndex = isActive ? 0 : -1;
      });
    };

    const clearMotion = () => {
      if (transitionCleanup) window.clearTimeout(transitionCleanup);
      transitionCleanup = undefined;
      carousel.classList.remove('is-transitioning');
      delete carousel.dataset.direction;
      slides.forEach((slide) => {
        delete slide.dataset.motion;
      });
    };

    const markMotion = (
      previousIndex: number,
      nextIndex: number,
      direction: 'next' | 'prev',
    ) => {
      clearMotion();
      if (reduceMotion.matches) return;

      carousel.classList.add('is-transitioning');
      carousel.dataset.direction = direction;
      slides[previousIndex].dataset.motion = `leave-${direction}`;
      slides[nextIndex].dataset.motion = `enter-${direction}`;

      transitionCleanup = window.setTimeout(clearMotion, 820);
    };

    const stopAuto = () => {
      if (timer) window.clearInterval(timer);
      timer = undefined;
    };

    const startAuto = () => {
      stopAuto();
      if (reduceMotion.matches) return;
      timer = window.setInterval(() => {
        goTo(normalize(activeIndex + 1), 'next');
      }, intervalMs);
    };

    const pauseAutoBriefly = () => {
      stopAuto();
      if (scrollResumeTimer) window.clearTimeout(scrollResumeTimer);
      scrollResumeTimer = window.setTimeout(() => {
        scrollResumeTimer = undefined;
        startAuto();
      }, 1200);
    };

    const goTo = (index: number, directionHint?: 'next' | 'prev') => {
      const nextIndex = clamp(index);
      if (nextIndex === activeIndex) {
        startAuto();
        return;
      }

      const previousIndex = activeIndex;
      const direction =
        directionHint ?? (nextIndex > activeIndex ? 'next' : 'prev');
      activeIndex = nextIndex;
      render();
      markMotion(previousIndex, nextIndex, direction);
      startAuto();
    };

    slides.forEach((slide, index) => {
      slide.addEventListener('click', (event) => {
        if (didSwipe) {
          event.preventDefault();
          return;
        }

        goTo(index);
      });
    });

    prev?.addEventListener('click', () =>
      goTo(normalize(activeIndex - 1), 'prev'),
    );
    next?.addEventListener('click', () =>
      goTo(normalize(activeIndex + 1), 'next'),
    );

    carousel.addEventListener('pointerdown', (event) => {
      didSwipe = false;
      pointerStartX = event.clientX;
      stopAuto();
    });

    carousel.addEventListener('pointerup', (event) => {
      if (pointerStartX === undefined) return;
      const delta = event.clientX - pointerStartX;
      pointerStartX = undefined;

      if (Math.abs(delta) > 48) {
        const direction = delta < 0 ? 'next' : 'prev';
        didSwipe = true;
        goTo(
          normalize(activeIndex + (direction === 'next' ? 1 : -1)),
          direction,
        );
        window.setTimeout(() => {
          didSwipe = false;
        });
        return;
      }

      startAuto();
    });

    carousel.addEventListener('pointercancel', () => {
      pointerStartX = undefined;
      startAuto();
    });

    carousel.addEventListener('mouseenter', stopAuto);
    carousel.addEventListener('mouseleave', startAuto);
    carousel.addEventListener('focusin', stopAuto);
    carousel.addEventListener('focusout', startAuto);
    window.addEventListener('wheel', pauseAutoBriefly, { passive: true });
    window.addEventListener('touchmove', pauseAutoBriefly, { passive: true });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAuto();
      } else {
        startAuto();
      }
    });

    render();
    startAuto();
  }
</script>
