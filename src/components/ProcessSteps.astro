---
import Container from './ui/Container.astro';
import { processSteps } from '../data/contacts';
---

<section id="process" class="process-section anchor-offset">
  <Container class="process-section__inner !max-w-[1480px]">
    <div class="process-section__header">
      <h2>Шаги подачи документов</h2>
    </div>

    <ol class="process-timeline" aria-label="Шаги подачи документов">
      {
        processSteps.map((step) => (
          <li class="process-step">
            <div class="process-step__marker">
              <span>{String(step.number).padStart(2, '0')}</span>
            </div>
            <div class="process-step__content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <p class="process-note">
      Подписание контракта — добровольное действие. Нормально брать паузу,
      перепроверять документы и задавать столько вопросов, сколько необходимо.
    </p>
  </Container>
</section>

<style>
  .process-section {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    padding: clamp(52px, 6vw, 86px) 0;
    color: #004329;
    background: #fbfcff;
  }

  .process-section::before,
  .process-section::after {
    position: absolute;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .process-section::before {
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      linear-gradient(0deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      repeating-linear-gradient(
        132deg,
        transparent 0 138px,
        rgb(29 78 216 / 0.105) 139px 140px,
        transparent 141px 280px
      );
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    opacity: 0.92;
  }

  .process-section::after {
    inset: clamp(34px, 5vw, 84px) clamp(20px, 5vw, 92px);
    z-index: -1;
    background:
      linear-gradient(rgb(15 23 42 / 0.14), rgb(15 23 42 / 0.14)) left top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) left top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        1px 148px no-repeat;
    opacity: 0.82;
  }

  .process-section__inner {
    position: relative;
    z-index: 1;
  }

  .process-section__header {
    margin-bottom: clamp(34px, 4.8vw, 66px);
    text-align: center;
  }

  .process-section__header h2 {
    margin: 0;
    color: #004329;
    font-size: 2rem;
    font-weight: 700;
    line-height: 0.92;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .process-timeline {
    --timeline-accent: #b80008;
    --timeline-line: rgb(184 0 8 / 0.82);

    position: relative;
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: clamp(12px, 1.2vw, 20px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .process-timeline::before {
    position: absolute;
    top: 31px;
    left: calc(100% / 14);
    right: calc(100% / 14);
    height: 2px;
    background: var(--timeline-line);
    content: '';
  }

  .process-step {
    position: relative;
    min-width: 0;
    text-align: center;
  }

  .process-step__marker {
    position: relative;
    z-index: 1;
    display: grid;
    width: 64px;
    height: 64px;
    margin: 0 auto clamp(16px, 1.8vw, 24px);
    place-items: center;
    border: 1.5px solid var(--timeline-accent);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.82), rgb(255 255 255 / 0.6)),
      #fbfcff;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.92),
      0 14px 32px rgb(15 23 42 / 0.06);
  }

  .process-step__marker span {
    color: #001a12;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
  }

  .process-step__content h3 {
    margin: 0 0 8px;
    color: #004329;
    font-size: clamp(0.82rem, 0.9vw, 1.05rem);
    font-weight: 700;
    line-height: 1.08;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .process-step__content p {
    margin: 0 auto;
    max-width: 18rem;
    color: rgb(15 23 42 / 0.68);
    font-size: clamp(0.76rem, 0.78vw, 0.9rem);
    font-weight: 400;
    line-height: 1.35;
  }

  .process-note {
    width: min(100%, 860px);
    margin: clamp(28px, 3vw, 44px) auto 0;
    color: rgb(15 23 42 / 0.68);
    font-size: clamp(0.92rem, 1vw, 1rem);
    font-weight: 400;
    line-height: 1.4;
    text-align: center;
  }

  @media (min-width: 640px) {
    .process-section__header h2 {
      font-size: 3.2rem;
    }
  }

  @media (min-width: 1024px) {
    .process-section__header h2 {
      font-size: 4.45rem;
    }
  }

  @media (max-width: 1180px) {
    .process-section__inner {
      max-width: 760px !important;
    }

    .process-timeline {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .process-timeline::before {
      top: 0;
      bottom: 0;
      left: 31px;
      right: auto;
      width: 2px;
      height: auto;
    }

    .process-step {
      display: grid;
      grid-template-columns: 64px minmax(0, 1fr);
      column-gap: clamp(18px, 4vw, 30px);
      padding-bottom: clamp(24px, 4vw, 34px);
      text-align: left;
    }

    .process-step:last-child {
      padding-bottom: 0;
    }

    .process-step__marker {
      margin: 0;
    }

    .process-step__content {
      padding-top: 8px;
    }

    .process-step__content p {
      max-width: none;
      margin: 0;
    }
  }

  @media (max-width: 640px) {
    .process-section {
      padding: 52px 0;
    }

    .process-section__header {
      margin-bottom: 34px;
    }

    .process-step {
      grid-template-columns: 54px minmax(0, 1fr);
      column-gap: 16px;
    }

    .process-timeline::before {
      left: 26px;
    }

    .process-step__marker {
      width: 54px;
      height: 54px;
    }

    .process-step__marker span {
      font-size: 0.92rem;
    }

    .process-step__content h3 {
      font-size: 0.98rem;
    }

    .process-step__content p {
      font-size: 0.86rem;
    }
  }

  :global(html[data-theme='dark']) .process-section {
    color: #e2e8f0;
    background: #060d1b;
  }

  :global(html[data-theme='dark']) .process-section::before {
    background:
      linear-gradient(90deg, rgb(148 163 184 / 0.08) 1px, transparent 1px)
        50% 0 / 96px 96px,
      linear-gradient(0deg, rgb(148 163 184 / 0.08) 1px, transparent 1px)
        50% 0 / 96px 96px,
      repeating-linear-gradient(
        132deg,
        transparent 0 138px,
        rgb(96 165 250 / 0.12) 139px 140px,
        transparent 141px 280px
      );
    opacity: 0.82;
  }

  :global(html[data-theme='dark']) .process-section::after {
    opacity: 0.5;
    filter: invert(1) opacity(0.72);
  }

  :global(html[data-theme='dark']) .process-timeline {
    --timeline-accent: #bfdbfe;
    --timeline-line: rgb(191 219 254 / 0.62);
  }

  :global(html[data-theme='dark']) .process-section__header h2,
  :global(html[data-theme='dark']) .process-step__content h3 {
    color: #ffffff;
  }

  :global(html[data-theme='dark']) .process-step__marker {
    border-color: rgb(191 219 254 / 0.9);
    background:
      linear-gradient(180deg, rgb(15 23 42 / 0.86), rgb(15 23 42 / 0.66)),
      #060d1b;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 18px 42px rgb(0 0 0 / 0.22);
  }

  :global(html[data-theme='dark']) .process-step__marker span {
    color: #ffffff;
  }

  :global(html[data-theme='dark']) .process-step__content p,
  :global(html[data-theme='dark']) .process-note {
    color: #f8fafc;
  }
</style>
