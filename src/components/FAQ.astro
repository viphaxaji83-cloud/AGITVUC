---
import Container from './ui/Container.astro';
import SectionTitle from './ui/SectionTitle.astro';
import Icon from './ui/Icon.astro';
import { faq } from '../data/faq';
---

<section id="faq" class="section bg-ink-50/60 anchor-offset">
  <Container class="grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <SectionTitle
        eyebrow="Частые вопросы"
        title="Что чаще всего спрашивают студенты"
        subtitle="Если нужного вопроса нет — напишите в форме внизу страницы. Ответим спокойно и без давления."
      />
    </div>

    <div class="lg:col-span-8">
      <ul class="divide-y divide-ink-200 rounded-2xl border border-ink-200 bg-white">
        {
          faq.map((item, i) => (
            <li>
              <details class="group" {...(i === 0 ? { open: true } : {})}>
                <summary class="flex items-center justify-between gap-4 px-5 py-4 sm:px-6 sm:py-5 hover:bg-ink-50/70 focus-visible:bg-ink-50/70 rounded-2xl">
                  <span class="text-base sm:text-lg font-medium text-ink-900">
                    {item.question}
                  </span>
                  <span class="text-brand-700 transition-transform group-open:rotate-180">
                    <Icon name="chevron" size={22} />
                  </span>
                </summary>
                <div class="px-5 pb-5 sm:px-6 sm:pb-6 text-ink-600 leading-relaxed">
                  {item.answer}
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</section>
