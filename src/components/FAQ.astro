---
import Container from './ui/Container.astro';
import { faq } from '../data/faq';
---

<section id="faq" class="faq-section section anchor-offset">
  <Container class="!max-w-[1320px]">
    <div class="faq-browser" data-faq-browser>
      <div class="faq-browser__questions">
        <div class="faq-browser__heading">
          <h2>Частые вопросы</h2>
        </div>

        <ol class="faq-question-list" aria-label="Список частых вопросов" data-faq-scroll>
          {
            faq.map((item, i) => (
              <li>
                <button
                  type="button"
                  class:list={['faq-question', i === 0 && 'is-active']}
                  data-faq-button
                  data-faq-index={i}
                  aria-controls={`faq-answer-${i}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                >
                  <span class="faq-question__text">{item.question}</span>
                </button>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="faq-browser__answer" aria-live="polite">
        {
          faq.map((item, i) => (
            <article
              id={`faq-answer-${i}`}
              class="faq-answer"
              data-faq-panel
              hidden={i !== 0}
            >
              <p>{item.answer}</p>
            </article>
          ))
        }
      </div>
    </div>
  </Container>
</section>

<style>
  .faq-section {
    padding: clamp(54px, 6.5vw, 92px) 0;
    color: #004329;
  }

  .faq-browser {
    display: grid;
    grid-template-columns: minmax(18rem, 25rem) minmax(0, 46rem);
    min-height: clamp(220px, 20vw, 280px);
    overflow: hidden;
    background: transparent;
  }

  .faq-browser__questions {
    display: flex;
    min-height: 0;
    flex-direction: column;
    padding: clamp(12px, 1.35vw, 18px);
  }

  .faq-browser__heading h2 {
    margin: 0;
    color: #004329;
    font-size: clamp(1.65rem, 2.6vw, 2.8rem);
    font-weight: 700;
    line-height: 0.92;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .faq-question-list {
    display: grid;
    max-height: var(--faq-list-height, 35rem);
    margin: clamp(26px, 3vw, 42px) 0 0;
    padding: 0 10px 0 0;
    border-right: 1px solid rgb(15 23 42 / 0.16);
    list-style: none;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-color: rgb(0 67 41 / 0.32) transparent;
    scrollbar-width: thin;
    touch-action: pan-y;
    user-select: none;
    cursor: grab;
  }

  .faq-question-list.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .faq-question-list li {
    border-top: 1px solid rgb(15 23 42 / 0.14);
  }

  .faq-question-list li:last-child {
    border-bottom: 1px solid rgb(15 23 42 / 0.14);
  }

  .faq-question {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    width: 100%;
    align-items: start;
    border: 0;
    background: transparent;
    padding: 13px 0;
    color: #004329;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }

  .faq-question:hover,
  .faq-question.is-active {
    color: #b80008;
  }

  .faq-question__text {
    font-size: clamp(0.94rem, 1vw, 1.04rem);
    font-weight: 400;
    line-height: 1.18;
    text-wrap: balance;
  }

  .faq-browser__answer {
    position: relative;
    display: flex;
    width: 100%;
    max-width: 46rem;
    min-height: 0;
    flex-direction: column;
    justify-content: center;
    padding: clamp(18px, 2.6vw, 34px);
  }

  .faq-answer[hidden] {
    display: none;
  }

  .faq-answer p {
    max-width: 44rem;
    margin: 0;
    color: rgb(15 23 42 / 0.68);
    font-size: clamp(0.84rem, 0.9vw, 0.94rem);
    line-height: 1.36;
    text-wrap: pretty;
  }

  @media (max-width: 900px) {
    .faq-browser {
      grid-template-columns: 1fr;
    }

    .faq-browser__questions {
      border-right: 0;
    }

    .faq-question-list {
      max-height: 310px;
      border-right: 0;
    }

    .faq-browser__answer {
      min-height: 320px;
      justify-content: flex-start;
      padding-top: 72px;
    }
  }

  @media (max-width: 640px) {
    .faq-section {
      padding: 52px 0;
    }

    .faq-browser {
      min-height: 0;
    }

    .faq-browser__heading h2 {
      white-space: normal;
      text-wrap: balance;
    }

    .faq-browser__questions,
    .faq-browser__answer {
      padding-inline: 18px;
    }

    .faq-question {
      padding: 16px 0;
    }
  }

  :global(html[data-theme='dark']) .faq-browser__heading h2,
  :global(html[data-theme='dark']) .faq-question {
    color: #ffffff;
  }

  :global(html[data-theme='dark']) .faq-question-list,
  :global(html[data-theme='dark']) .faq-question-list li {
    border-color: rgb(148 163 184 / 0.22);
  }

  :global(html[data-theme='dark']) .faq-answer p {
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .faq-question:hover,
  :global(html[data-theme='dark']) .faq-question.is-active {
    color: #bfdbfe;
  }
</style>

<script>
  const faqBrowsers = document.querySelectorAll<HTMLElement>('[data-faq-browser]');

  faqBrowsers.forEach((browser) => {
    const buttons = Array.from(
      browser.querySelectorAll<HTMLButtonElement>('[data-faq-button]'),
    );
    const panels = Array.from(
      browser.querySelectorAll<HTMLElement>('[data-faq-panel]'),
    );
    const questionList = browser.querySelector<HTMLElement>('[data-faq-scroll]');

    const setQuestionListHeight = () => {
      if (!questionList || questionList.children.length <= 10) {
        questionList?.style.removeProperty('--faq-list-height');
        return;
      }

      const visibleItems = Array.from(questionList.children).slice(0, 10) as HTMLElement[];
      const height = visibleItems.reduce((sum, item) => sum + item.offsetHeight, 0);
      questionList.style.setProperty('--faq-list-height', `${height}px`);
    };

    const selectAnswer = (index: string) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.faqIndex === index;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach((panel, panelIndex) => {
        panel.hidden = String(panelIndex) !== index;
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        if (button.dataset.faqIndex) {
          selectAnswer(button.dataset.faqIndex);
        }
      });
    });

    if (questionList) {
      let startY = 0;
      let startScrollTop = 0;
      let activePointerId: number | null = null;
      let hasDragged = false;
      let suppressClick = false;

      questionList.addEventListener(
        'click',
        (event) => {
          if (suppressClick) {
            event.preventDefault();
            event.stopPropagation();
            suppressClick = false;
          }
        },
        true,
      );

      questionList.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'mouse' || event.button !== 0) {
          return;
        }

        activePointerId = event.pointerId;
        startY = event.clientY;
        startScrollTop = questionList.scrollTop;
        hasDragged = false;
      });

      window.addEventListener('pointermove', (event) => {
        if (activePointerId !== event.pointerId) {
          return;
        }

        const deltaY = event.clientY - startY;
        if (Math.abs(deltaY) > 3) {
          hasDragged = true;
          questionList.classList.add('is-dragging');
          questionList.scrollTop = startScrollTop - deltaY;
          event.preventDefault();
        }
      });

      const finishDrag = (event: PointerEvent) => {
        if (activePointerId !== event.pointerId) {
          return;
        }

        activePointerId = null;
        questionList.classList.remove('is-dragging');

        if (hasDragged) {
          suppressClick = true;
          window.setTimeout(() => {
            suppressClick = false;
          }, 120);
        }
      };

      window.addEventListener('pointerup', finishDrag);
      window.addEventListener('pointercancel', finishDrag);
    }

    setQuestionListHeight();
    window.addEventListener('resize', setQuestionListHeight);
  });
</script>
