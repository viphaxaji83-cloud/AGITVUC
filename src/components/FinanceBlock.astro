---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';

const conditions = [
  {
    title: 'Выплаты',
    description:
      'Состав и порядок выплат уточняются по официальным документам и условиям конкретного контракта.',
    icon: 'salary',
  },
  {
    title: 'Льготы',
    description:
      'Возможные меры поддержки зависят от статуса, региона, направления службы и действующих нормативных актов.',
    icon: 'compensation',
  },
  {
    title: 'Документы',
    description:
      'На консультации помогают понять, какие документы понадобятся и в каком порядке их готовить.',
    icon: 'docs',
  },
  {
    title: 'Отбор',
    description:
      'Требования и этапы отбора заранее разбираются с ответственным сотрудником университета.',
    icon: 'check',
  },
  {
    title: 'Сроки',
    description:
      'Ключевые даты, порядок подачи заявления и дальнейшие шаги лучше сверить до принятия решения.',
    icon: 'clock',
  },
  {
    title: 'Здоровье',
    description:
      'Медицинские вопросы и требования обсуждаются отдельно, с опорой на официальные процедуры.',
    icon: 'medical',
  },
  {
    title: 'Права',
    description:
      'Перед подписанием документов важно спокойно разобрать права, обязанности и последствия контракта.',
    icon: 'legal',
  },
  {
    title: 'Консультация',
    description:
      'Все условия можно уточнить без давления: получить разъяснения, задать вопросы и взять время на решение.',
    icon: 'consult',
  },
] as const;
---

<section id="finance" class="conditions-section anchor-offset">
  <Container class="conditions-section__inner !max-w-[1360px]">
    <div class="conditions-section__header">
      <h2>ВОЗМОЖНОСТИ ДЛЯ СТУДЕНТОВ</h2>
    </div>

    <div class="conditions-grid" aria-label="Условия контрактной службы">
      {
        conditions.map((item) => (
          <article class="conditions-card">
            <span class="conditions-card__icon" aria-hidden="true">
              <Icon name={item.icon} size={22} />
            </span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .conditions-section {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: calc(100svh - 4rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(72px, 9vw, 124px) 0;
    color: #004329;
    background: #fbfcff;
  }

  .conditions-section::before,
  .conditions-section::after {
    position: absolute;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .conditions-section::before {
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      linear-gradient(0deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      repeating-linear-gradient(
        132deg,
        transparent 0 138px,
        rgb(29 78 216 / 0.105) 139px 140px,
        transparent 141px 280px
      );
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    opacity: 0.92;
  }

  .conditions-section::after {
    inset: clamp(34px, 5vw, 84px) clamp(20px, 5vw, 92px);
    z-index: -1;
    background:
      linear-gradient(rgb(15 23 42 / 0.14), rgb(15 23 42 / 0.14)) left top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) left top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        1px 148px no-repeat;
    opacity: 0.82;
  }

  .conditions-section__inner {
    position: relative;
    z-index: 1;
    transform: translateY(clamp(-72px, -5.4vw, -42px));
  }

  .conditions-section__header {
    margin-bottom: clamp(28px, 4vw, 44px);
    text-align: center;
  }

  .conditions-section__header h2 {
    margin: 0;
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 0.92;
    color: #004329;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .conditions-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(22px, 2.4vw, 34px);
  }

  .conditions-card {
    min-height: clamp(198px, 18vw, 220px);
    border: 1px solid rgb(15 23 42 / 0.16);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.7), rgb(255 255 255 / 0.48)),
      rgb(255 255 255 / 0.42);
    padding: clamp(22px, 2.4vw, 28px);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.78),
      0 16px 36px rgb(15 23 42 / 0.06);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .conditions-card:hover {
    border-color: rgb(0 67 41 / 0.28);
    background-color: rgb(255 255 255 / 0.64);
    transform: translateY(-2px);
  }

  .conditions-card__icon {
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    border: 1px solid rgb(15 23 42 / 0.18);
    border-radius: 6px;
    color: #004329;
    background: rgb(255 255 255 / 0.62);
  }

  .conditions-card h3 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.08;
    color: #004329;
    text-transform: uppercase;
  }

  .conditions-card p {
    margin: 0;
    color: rgb(15 23 42 / 0.68);
    font-size: 0.94rem;
    font-weight: 400;
    line-height: 1.35;
  }

  @media (min-width: 640px) {
    .conditions-section__header h2 {
      font-size: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .conditions-section__header h2 {
      font-size: 5.8rem;
    }

    .conditions-card h3 {
      font-size: 1.35rem;
    }

    .conditions-card p {
      font-size: 1rem;
    }
  }

  @media (max-width: 1180px) {
    .conditions-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 960px) {
    .conditions-section {
      min-height: auto;
    }

    .conditions-section__inner {
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .conditions-section {
      padding: 64px 0;
    }

    .conditions-grid {
      grid-template-columns: 1fr;
    }

    .conditions-card {
      min-height: 0;
    }
  }
</style>
