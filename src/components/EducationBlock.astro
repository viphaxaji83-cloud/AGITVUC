---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';

const advantages = [
  {
    title: 'Технологии',
    description:
      'Знакомство с современными беспилотными системами, средствами управления и практическими сценариями применения.',
    icon: 'drone',
  },
  {
    title: 'Обучение',
    description:
      'Понятная образовательная траектория: консультации, разбор направлений и помощь с выбором подходящего формата.',
    icon: 'education',
  },
  {
    title: 'Поддержка',
    description:
      'Университет помогает с документами, этапами оформления и ответами на организационные вопросы.',
    icon: 'support',
  },
  {
    title: 'Практика',
    description:
      'Акцент на прикладные навыки: безопасность, связь, техническая подготовка и работа в команде.',
    icon: 'engineering',
  },
  {
    title: 'Выплаты',
    description:
      'Финансовые условия и доступные меры поддержки обсуждаются заранее на консультации.',
    icon: 'finance',
  },
  {
    title: 'Перспектива',
    description:
      'Опыт, который может стать стартом для инженерной, технической или управленческой траектории.',
    icon: 'career',
  },
] as const;
---

<section id="education" class="advantages-section anchor-offset">
  <Container class="advantages-section__inner">
    <div class="advantages-section__header">
      <h2>Преимущества</h2>
    </div>

    <div class="advantages-grid" aria-label="Преимущества программы">
      {
        advantages.map((item) => (
          <article class="advantages-card">
            <span class="advantages-card__icon" aria-hidden="true">
              <Icon name={item.icon} size={22} />
            </span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .advantages-section {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: calc(100svh - 4rem);
    align-items: center;
    overflow: hidden;
    padding: clamp(72px, 9vw, 124px) 0;
    color: #004329;
    background: #fbfcff;
  }

  .advantages-section::before,
  .advantages-section::after {
    position: absolute;
    inset: 0;
    content: '';
    pointer-events: none;
  }

  .advantages-section::before {
    z-index: -1;
    background:
      linear-gradient(90deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      linear-gradient(0deg, rgb(15 23 42 / 0.075) 1px, transparent 1px)
        50% 0 / 96px 96px,
      repeating-linear-gradient(
        132deg,
        transparent 0 138px,
        rgb(29 78 216 / 0.105) 139px 140px,
        transparent 141px 280px
      );
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 14%,
      #000 86%,
      transparent 100%
    );
    opacity: 0.92;
  }

  .advantages-section::after {
    inset: clamp(34px, 5vw, 84px) clamp(20px, 5vw, 92px);
    z-index: -1;
    background:
      linear-gradient(rgb(15 23 42 / 0.14), rgb(15 23 42 / 0.14)) left top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) left top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) right top /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.16), rgb(15 23 42 / 0.16)) left bottom /
        1px 148px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        148px 1px no-repeat,
      linear-gradient(rgb(15 23 42 / 0.18), rgb(15 23 42 / 0.18)) right bottom /
        1px 148px no-repeat;
    opacity: 0.82;
  }

  .advantages-section__inner {
    position: relative;
    z-index: 1;
    transform: translateY(clamp(-72px, -5.4vw, -42px));
  }

  .advantages-section__header {
    margin-bottom: clamp(28px, 4vw, 44px);
    text-align: center;
  }

  .advantages-section__header h2 {
    margin: 0;
    max-width: none;
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 0.92;
    color: #004329;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .advantages-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(18px, 2.2vw, 28px);
  }

  .advantages-card {
    min-height: clamp(214px, 20vw, 238px);
    border: 1px solid rgb(15 23 42 / 0.16);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.7), rgb(255 255 255 / 0.48)),
      rgb(255 255 255 / 0.42);
    padding: clamp(24px, 3vw, 30px);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.78),
      0 16px 36px rgb(15 23 42 / 0.06);
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .advantages-card:hover {
    border-color: rgb(0 67 41 / 0.28);
    background-color: rgb(255 255 255 / 0.64);
    transform: translateY(-2px);
  }

  .advantages-card__icon {
    display: inline-flex;
    width: 42px;
    height: 42px;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    border: 1px solid rgb(15 23 42 / 0.18);
    border-radius: 6px;
    color: #004329;
    background: rgb(255 255 255 / 0.62);
  }

  .advantages-card h3 {
    margin: 0 0 8px;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.08;
    color: #004329;
    text-transform: uppercase;
  }

  .advantages-card p {
    margin: 0;
    max-width: 32rem;
    color: rgb(15 23 42 / 0.68);
    font-size: 0.98rem;
    font-weight: 400;
    line-height: 1.35;
  }

  @media (min-width: 640px) {
    .advantages-section__header h2 {
      font-size: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .advantages-section__header h2 {
      font-size: 5.8rem;
    }

    .advantages-card h3 {
      font-size: 1.45rem;
    }

    .advantages-card p {
      font-size: 1.06rem;
    }
  }

  @media (max-width: 960px) {
    .advantages-section {
      min-height: auto;
    }

    .advantages-section__inner {
      transform: none;
    }

    .advantages-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .advantages-section {
      padding: 64px 0;
    }

    .advantages-grid {
      grid-template-columns: 1fr;
    }

    .advantages-card {
      min-height: 0;
    }
  }
</style>
