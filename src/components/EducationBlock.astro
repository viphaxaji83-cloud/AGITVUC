---
import Container from './ui/Container.astro';
import SectionTitle from './ui/SectionTitle.astro';
import Card from './ui/Card.astro';
import Icon from './ui/Icon.astro';
import DisclaimerNote from './ui/DisclaimerNote.astro';
import Button from './ui/Button.astro';
import { educationTopics } from '../data/support';
---

<section id="education" class="section anchor-offset">
  <Container class="grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-5 flex flex-col gap-6">
      <SectionTitle
        eyebrow="Образование и университет"
        title="Возможные образовательные сценарии"
        subtitle="Решения по образовательной траектории принимают ответственные подразделения университета. Ниже — темы, которые имеет смысл обсудить на консультации."
      />

      <DisclaimerNote
        text="Возможные образовательные сценарии зависят от статуса студента, документов и решений ответственных подразделений. Уточните порядок на консультации."
      />

      <div class="flex flex-wrap gap-2">
        <Button href="#contacts" size="md">
          Получить консультацию
          <Icon name="arrow-right" size={18} />
        </Button>
        <Button href="#faq" variant="secondary" size="md">
          Посмотреть вопросы
        </Button>
      </div>
    </div>

    <div class="lg:col-span-7">
      <ol class="grid gap-3 sm:grid-cols-2">
        {
          educationTopics.map((t, i) => (
            <Card
              as="li"
              class="flex flex-col gap-2 h-full"
              variant={i === 0 ? 'gradient' : 'default'}
            >
              <div class="flex items-center gap-3">
                <span
                  class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-brand-50 text-brand-700 font-semibold"
                  aria-hidden="true"
                >
                  {i + 1}
                </span>
                <h3 class="text-base font-semibold text-ink-900">
                  {t.title}
                </h3>
              </div>
              <p class="text-sm text-ink-600 leading-relaxed">
                {t.description}
              </p>
            </Card>
          ))
        }
      </ol>
    </div>
  </Container>
</section>
