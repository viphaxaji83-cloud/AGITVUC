---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-ink-950 text-white anchor-offset"
>
  <picture aria-hidden="true">
    <source srcset="/hero-bpla-training-v4.webp" type="image/webp" />
    <img
      src="/hero-bpla-training-v4.webp"
      alt=""
      class="absolute inset-0 -z-30 h-full w-full object-cover object-[36%_center] sm:object-[58%_center]"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  <div class="absolute inset-0 -z-20 bg-ink-950/20" aria-hidden="true"></div>
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(3,7,18,0.86)_0%,rgba(15,23,42,0.42)_48%,rgba(15,23,42,0.05)_100%),linear-gradient(0deg,rgba(3,7,18,0.84)_0%,rgba(3,7,18,0.18)_52%,rgba(3,7,18,0.22)_100%)]"
    aria-hidden="true"
  >
  </div>

  <Container
    class="relative flex min-h-[calc(100svh-4rem)] !max-w-[1760px] flex-col justify-end py-10 sm:!px-8 sm:py-14 lg:min-h-[calc(100svh-4rem)] lg:!px-20 lg:py-16 xl:!px-24"
  >
    <div class="flex max-w-[780px] flex-col gap-6 pb-12 sm:pb-16 lg:pb-24">
      <div class="flex flex-col gap-8 animate-fade-up sm:gap-10">
        <h1
          class="max-w-[780px] text-[2.55rem] font-bold uppercase leading-[1.05] text-white drop-shadow-[0_6px_24px_rgba(0,0,0,0.45)] sm:text-6xl lg:text-[4rem] xl:text-[4.25rem]"
        >
          <span class="hidden sm:block">
            Контрактная служба
          </span>
          <span class="hidden sm:block">для&nbsp;студентов</span>
          <span class="block sm:hidden">Контрактная</span>
          <span class="block sm:hidden">служба</span>
          <span class="block sm:hidden">для студентов</span>
        </h1>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="#contacts"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-brand-900 shadow-[0_16px_36px_rgba(0,0,0,0.24)] transition-colors hover:bg-brand-50 sm:text-lg"
          >
            Получить консультацию
            <Icon name="arrow-right" size={20} />
          </a>
          <a
            href="#directions"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-white/30 bg-white/14 px-6 py-3 text-base font-semibold text-white shadow-[0_16px_36px_rgba(0,0,0,0.18)] backdrop-blur-md transition-colors hover:border-white/60 hover:bg-white/24 sm:text-lg"
          >
            Смотреть направления
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
