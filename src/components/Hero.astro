---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';
import { site } from '../data/site';
---

<section
  id="hero"
  class="relative isolate overflow-hidden bg-ink-950 text-white anchor-offset"
>
  <picture aria-hidden="true">
    <source srcset="/hero-bpla-training-v4.webp" type="image/webp" />
    <img
      src="/hero-bpla-training-v4.webp"
      alt=""
      class="absolute inset-0 -z-30 h-full w-full object-cover object-[36%_center] sm:object-[58%_center]"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  <div class="absolute inset-0 -z-20 bg-ink-950/20" aria-hidden="true"></div>
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(3,7,18,0.86)_0%,rgba(15,23,42,0.42)_48%,rgba(15,23,42,0.05)_100%),linear-gradient(0deg,rgba(3,7,18,0.84)_0%,rgba(3,7,18,0.18)_52%,rgba(3,7,18,0.22)_100%)]"
    aria-hidden="true"
  >
  </div>

  <Container
    class="relative flex min-h-[calc(100svh-4rem)] !max-w-[1760px] flex-col justify-end py-10 sm:!px-8 sm:py-14 lg:min-h-[calc(100svh-4rem)] lg:!px-20 lg:py-16 xl:!px-24"
  >
    <div class="flex max-w-[780px] flex-col gap-6 pb-3 sm:pb-8 lg:pb-10">
      <div class="flex flex-col gap-5 animate-fade-up">
        <span
          class="inline-flex items-center gap-2 self-start rounded-full border border-white/25 bg-white/14 px-4 py-2 text-xs font-semibold uppercase text-white shadow-[0_14px_32px_rgba(0,0,0,0.24)] backdrop-blur-md"
        >
          <span
            class="h-2 w-2 rounded-full bg-accent-red"
            aria-hidden="true"></span>
          Информационный раздел · {site.university}
        </span>

        <h1
          class="max-w-[780px] text-[2.55rem] font-bold uppercase leading-[1.05] text-white drop-shadow-[0_6px_24px_rgba(0,0,0,0.45)] sm:text-6xl lg:text-[4rem] xl:text-[4.25rem]"
        >
          <span class="hidden sm:block">
            Контрактная служба
          </span>
          <span class="hidden sm:block">для&nbsp;студентов</span>
          <span class="block sm:hidden">Контрактная</span>
          <span class="block sm:hidden">служба</span>
          <span class="block sm:hidden">для студентов</span>
        </h1>

        <div
          class="h-1.5 w-full max-w-[360px] rounded-full bg-[linear-gradient(90deg,#d62718_0%,#d62718_34%,#2563eb_34%,#2563eb_68%,#ffffff_68%,#ffffff_100%)] shadow-[0_4px_16px_rgba(0,0,0,0.35)]"
          aria-hidden="true"
        >
        </div>

        <p
          class="max-w-[700px] rounded-[28px] border border-white/20 bg-white/22 px-5 py-4 text-sm font-semibold uppercase leading-relaxed text-white shadow-[0_16px_44px_rgba(0,0,0,0.28)] backdrop-blur-md sm:text-lg"
        >
          <span class="hidden sm:inline">
            Разберитесь в направлениях, условиях и порядке официальной
            консультации. Без давления, с&nbsp;опорой на документы и поддержку
            университета.
          </span>
          <span class="sm:hidden">
            Разберитесь в направлениях и условиях. Консультация без
            обязательств.
          </span>
        </p>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a
            href="#contacts"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 text-base font-semibold text-brand-900 shadow-[0_16px_36px_rgba(0,0,0,0.24)] transition-colors hover:bg-brand-50 sm:text-lg"
          >
            Получить консультацию
            <Icon name="arrow-right" size={20} />
          </a>
          <a
            href="#directions"
            class="inline-flex items-center justify-center gap-2 rounded-full border border-white/30 bg-white/14 px-6 py-3 text-base font-semibold text-white shadow-[0_16px_36px_rgba(0,0,0,0.18)] backdrop-blur-md transition-colors hover:border-white/60 hover:bg-white/24 sm:text-lg"
          >
            Смотреть направления
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const hero = document.getElementById('hero');
  const benefits = document.getElementById('benefits');
  let isPageJumping = false;
  let jumpAnimationFrame: number | undefined;
  let jumpUnlockTimer: number | undefined;
  let touchStartY: number | undefined;

  const getHeaderOffset = () =>
    document.querySelector('header')?.getBoundingClientRect().height ?? 0;

  const getBenefitsTop = () => {
    if (!benefits) return 0;
    return benefits.getBoundingClientRect().top + window.scrollY - getHeaderOffset();
  };

  const getHeroTop = () => {
    if (!hero) return 0;
    return Math.max(
      0,
      hero.getBoundingClientRect().top + window.scrollY - getHeaderOffset(),
    );
  };

  const isInsideHeroScrollZone = () => {
    if (!hero || !benefits) return false;

    const headerOffset = getHeaderOffset();
    const heroRect = hero.getBoundingClientRect();
    const benefitsTop = getBenefitsTop();

    return (
      heroRect.top <= headerOffset + 8 &&
      heroRect.bottom > headerOffset + 96 &&
      window.scrollY < benefitsTop - 12
    );
  };

  const isInsideBenefitsScrollZone = () => {
    if (!benefits) return false;

    const headerOffset = getHeaderOffset();
    const benefitsRect = benefits.getBoundingClientRect();

    return (
      benefitsRect.top <= headerOffset + 96 &&
      benefitsRect.bottom > headerOffset + 160 &&
      window.scrollY > getHeroTop() + 12
    );
  };

  const finishPageJump = () => {
    if (jumpAnimationFrame) window.cancelAnimationFrame(jumpAnimationFrame);
    if (jumpUnlockTimer) window.clearTimeout(jumpUnlockTimer);
    jumpAnimationFrame = undefined;
    jumpUnlockTimer = undefined;
    isPageJumping = false;
    document.documentElement.classList.remove('is-instant-page-jump');
  };

  const jumpToPosition = (top: number) => {
    if (jumpAnimationFrame) window.cancelAnimationFrame(jumpAnimationFrame);
    if (jumpUnlockTimer) window.clearTimeout(jumpUnlockTimer);

    isPageJumping = true;
    document.documentElement.classList.add('is-instant-page-jump');

    const startY = window.scrollY;
    const distance = top - startY;
    const duration = Math.min(440, Math.max(280, Math.abs(distance) * 0.28));
    const startedAt = performance.now();

    const easeOutCubic = (progress: number) =>
      1 - Math.pow(1 - progress, 3);

    const step = (now: number) => {
      const progress = Math.min((now - startedAt) / duration, 1);
      const eased = easeOutCubic(progress);
      window.scrollTo(0, startY + distance * eased);

      if (progress < 1) {
        jumpAnimationFrame = window.requestAnimationFrame(step);
        return;
      }

      finishPageJump();
    };

    jumpAnimationFrame = window.requestAnimationFrame(step);
    jumpUnlockTimer = window.setTimeout(finishPageJump, duration + 120);
  };

  const jumpToHero = () => {
    if (!hero) return;
    jumpToPosition(getHeroTop());
  };

  const jumpToBenefits = () => {
    if (!benefits) return;
    jumpToPosition(getBenefitsTop());
  };

  const shouldIgnoreKeyTarget = (target: EventTarget | null) => {
    if (!(target instanceof HTMLElement)) return false;
    return Boolean(target.closest('input, textarea, select, button, a, [contenteditable]'));
  };

  window.addEventListener(
    'wheel',
    (event) => {
      if (isPageJumping) {
        event.preventDefault();
        return;
      }

      if (event.deltaY > 16 && isInsideHeroScrollZone()) {
        event.preventDefault();
        jumpToBenefits();
        return;
      }

      if (event.deltaY < -16 && isInsideBenefitsScrollZone()) {
        event.preventDefault();
        jumpToHero();
      }
    },
    { passive: false },
  );

  hero?.addEventListener(
    'touchstart',
    (event) => {
      touchStartY = event.touches[0]?.clientY;
    },
    { passive: true },
  );

  hero?.addEventListener(
    'touchmove',
    (event) => {
      if (touchStartY === undefined) return;

      const currentY = event.touches[0]?.clientY;
      if (currentY === undefined) return;

      const deltaY = touchStartY - currentY;
      if (deltaY <= 40 || !isInsideHeroScrollZone()) return;

      event.preventDefault();
      touchStartY = undefined;
      jumpToBenefits();
    },
    { passive: false },
  );

  benefits?.addEventListener(
    'touchstart',
    (event) => {
      touchStartY = event.touches[0]?.clientY;
    },
    { passive: true },
  );

  benefits?.addEventListener(
    'touchmove',
    (event) => {
      if (touchStartY === undefined) return;

      const currentY = event.touches[0]?.clientY;
      if (currentY === undefined) return;

      const deltaY = touchStartY - currentY;
      if (deltaY >= -40 || !isInsideBenefitsScrollZone()) return;

      event.preventDefault();
      touchStartY = undefined;
      jumpToHero();
    },
    { passive: false },
  );

  hero?.addEventListener('touchend', () => {
    touchStartY = undefined;
  });

  benefits?.addEventListener('touchend', () => {
    touchStartY = undefined;
  });

  document.addEventListener('keydown', (event) => {
    const isForwardScrollKey =
      event.code === 'ArrowDown' ||
      event.code === 'PageDown' ||
      (event.code === 'Space' && !event.shiftKey);

    const isBackwardScrollKey =
      event.code === 'ArrowUp' ||
      event.code === 'PageUp' ||
      (event.code === 'Space' && event.shiftKey);

    if (
      event.altKey ||
      event.ctrlKey ||
      event.metaKey ||
      shouldIgnoreKeyTarget(event.target)
    ) {
      return;
    }

    if (isForwardScrollKey && isInsideHeroScrollZone()) {
      event.preventDefault();
      jumpToBenefits();
      return;
    }

    if (isBackwardScrollKey && isInsideBenefitsScrollZone()) {
      event.preventDefault();
      jumpToHero();
    }
  });
</script>
