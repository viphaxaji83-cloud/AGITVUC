---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { formatNewsDate, getPrimaryNewsImage, type NewsItem } from '../../lib/news';

interface Props {
  news: NewsItem;
  priority?: boolean;
}

const { news, priority = false } = Astro.props;
const href = `/news/${news.slug}`;
const primaryImage = getPrimaryNewsImage(news);
---

<article class="news-card">
  <a class="news-card__media" href={href} aria-label={`Открыть новость: ${news.title}`} draggable="false">
    <img
      src={primaryImage.src}
      alt={primaryImage.alt}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      draggable="false"
    />
  </a>

  <div class="news-card__body">
    <time class="news-card__date" datetime={news.date}>
      {formatNewsDate(news.date)}
    </time>

    <h3 class="news-card__title">
      <a href={href}>{news.title}</a>
    </h3>

    <p class="news-card__excerpt">{news.excerpt}</p>

    <div class="news-card__actions">
      <Button href={href} size="sm">
        Посмотреть
        <Icon name="arrow-right" size={17} />
      </Button>
    </div>
  </div>
</article>

<style>
  .news-card {
    display: flex;
    height: 100%;
    min-height: 0;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgb(15 23 42 / 0.14);
    border-radius: 8px;
    background: rgb(255 255 255 / 0.72);
    box-shadow: 0 14px 34px rgb(15 23 42 / 0.055);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .news-card:hover {
    border-color: rgb(29 78 216 / 0.32);
    box-shadow: 0 18px 44px rgb(15 23 42 / 0.1);
    transform: translateY(-2px);
  }

  .news-card__media {
    display: block;
    aspect-ratio: 16 / 8.2;
    overflow: hidden;
    background: #e2e8f0;
  }

  .news-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    -webkit-user-drag: none;
    transition: transform 260ms ease;
  }

  .news-card:hover .news-card__media img {
    transform: scale(1.035);
  }

  .news-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(14px, 1.35vw, 17px);
  }

  .news-card__date {
    margin-bottom: 8px;
    color: #64748b;
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .news-card__title {
    display: -webkit-box;
    min-height: 2.42em;
    margin: 0;
    overflow: hidden;
    color: #004329;
    font-size: clamp(0.98rem, 1.02vw, 1.08rem);
    font-weight: 600;
    line-height: 1.21;
    overflow-wrap: anywhere;
    word-break: break-word;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .news-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .news-card__excerpt {
    display: -webkit-box;
    min-height: 4.2em;
    margin: 10px 0 16px;
    overflow: hidden;
    color: rgb(15 23 42 / 0.7);
    font-size: 0.88rem;
    line-height: 1.36;
    overflow-wrap: anywhere;
    word-break: break-word;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .news-card__actions {
    margin-top: auto;
  }

  :global(html[data-theme='dark']) .news-card {
    border-color: rgb(148 163 184 / 0.22);
    background: rgb(15 23 42 / 0.78);
    box-shadow: 0 20px 48px rgb(0 0 0 / 0.24);
  }

  :global(html[data-theme='dark']) .news-card:hover {
    border-color: rgb(96 165 250 / 0.42);
  }

  :global(html[data-theme='dark']) .news-card__title {
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .news-card__date {
    color: #93c5fd;
  }

  :global(html[data-theme='dark']) .news-card__excerpt {
    color: rgb(226 232 240 / 0.78);
  }
</style>
