---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';
import { site } from '../data/site';
import { contacts } from '../data/contacts';

const year = new Date().getFullYear();
---

<footer class="site-footer mt-auto border-t border-ink-200 bg-white">
  <Container>
    <div class="site-footer__inner">
      <div class="site-footer__main">
        <nav class="site-footer__section" aria-label="Разделы сайта">
          <h2>Разделы</h2>
          <ul class="site-footer__nav">
          {
            site.nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
          </ul>
        </nav>

        <section class="site-footer__section" aria-labelledby="footer-contacts-title">
          <h2 id="footer-contacts-title">Контакты</h2>
          <div class="site-footer__contacts">
            <a href={contacts.phoneHref} class="site-footer__contact">
              <Icon name="phone" size={16} />
              <span>{contacts.phone}</span>
            </a>
            <span class="site-footer__contact">
              <Icon name="pin" size={16} />
              <span>{contacts.address}</span>
            </span>
            <a href={`mailto:${contacts.email}`} class="site-footer__contact">
              <Icon name="mail" size={16} />
              <span>{contacts.email}</span>
            </a>
            <span class="site-footer__contact">
              <Icon name="clock" size={16} />
              <span>ПН-ПТ, {contacts.workingHours} (ПО МСК)</span>
            </span>
            <span class="site-footer__contact site-footer__contact--wide">
              <Icon name="shield-info" size={16} />
              <span>{contacts.responsibleUnit}</span>
            </span>
          </div>
        </section>
      </div>

      <div class="site-footer__copy">
        <span>© МГТУ {year} год.</span>
      </div>
    </div>
  </Container>
</footer>

<style>
  .site-footer {
    color: #0f172a;
  }

  .site-footer__inner {
    width: min(100%, 1136px);
    margin-inline: auto;
    padding-block: clamp(38px, 4.4vw, 48px) clamp(30px, 3.6vw, 40px);
  }

  .site-footer__main {
    display: grid;
    grid-template-columns: minmax(280px, 0.78fr) minmax(420px, 1.22fr);
    gap: clamp(64px, 10vw, 150px);
    align-items: start;
  }

  .site-footer__section h2 {
    margin: 0 0 18px;
    color: #475569;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 11px 38px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer a {
    color: inherit;
    text-decoration: none;
    transition: color 180ms ease;
  }

  .site-footer a:hover {
    color: #1d4ed8;
  }

  .site-footer__nav,
  .site-footer__contacts {
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .site-footer__contacts {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 12px 42px;
  }

  .site-footer__contact {
    display: inline-flex;
    min-width: 0;
    align-items: flex-start;
    gap: 8px;
  }

  .site-footer__contact svg {
    flex: 0 0 auto;
    margin-top: 1px;
    color: #475569;
  }

  .site-footer__contact--wide {
    grid-column: 1 / -1;
    width: fit-content;
    max-width: 100%;
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .site-footer__copy {
    display: flex;
    justify-content: center;
    margin-top: clamp(24px, 3vw, 32px);
    border-top: 1px solid rgb(15 23 42 / 0.14);
    padding-top: 22px;
    color: #64748b;
    font-size: 0.86rem;
    line-height: 1.2;
    text-align: center;
  }

  :global(html[data-theme='dark']) .site-footer {
    border-color: rgb(148 163 184 / 0.22);
    background: #111827 !important;
    color: #f8fafc;
  }

  :global(html[data-theme='dark']) .site-footer__section h2 {
    color: #94a3b8;
  }

  :global(html[data-theme='dark']) .site-footer a:hover {
    color: #bfdbfe;
  }

  :global(html[data-theme='dark']) .site-footer__contact svg,
  :global(html[data-theme='dark']) .site-footer__copy {
    color: #94a3b8;
  }

  :global(html[data-theme='dark']) .site-footer__copy {
    border-color: rgb(148 163 184 / 0.24);
  }

  @media (max-width: 900px) {
    .site-footer__main {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .site-footer__contacts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .site-footer__inner {
      padding-block: 32px;
    }

    .site-footer__nav,
    .site-footer__contacts {
      grid-template-columns: 1fr;
    }

    .site-footer__contact--wide {
      white-space: normal;
    }
  }
</style>
