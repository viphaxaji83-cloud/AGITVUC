---
import Container from './ui/Container.astro';
import Icon from './ui/Icon.astro';
import { site } from '../data/site';
import { contacts } from '../data/contacts';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-ink-200 bg-white">
  <Container class="py-12 sm:py-14">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="hidden lg:block lg:col-span-5"></div>

      <div class="lg:col-span-3">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-ink-500">
          Разделы
        </h2>
        <ul class="mt-4 grid gap-2 text-sm">
          {
            site.nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-ink-700 hover:text-brand-800"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-4 flex flex-col gap-3 text-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-ink-500">
          Контакты
        </h2>
        <a
          href={contacts.phoneHref}
          class="flex items-center gap-2 text-ink-700 hover:text-brand-800"
        >
          <Icon name="phone" size={16} />
          {contacts.phone}
        </a>
        <a
          href={`mailto:${contacts.email}`}
          class="flex items-center gap-2 text-ink-700 hover:text-brand-800"
        >
          <Icon name="mail" size={16} />
          {contacts.email}
        </a>
        <span class="flex items-start gap-2 text-ink-600">
          <Icon name="pin" size={16} />
          <span>{contacts.address}</span>
        </span>
        <span class="flex items-start gap-2 text-ink-600">
          <Icon name="clock" size={16} />
          <span>{contacts.workingHours}</span>
        </span>
        <span class="flex items-start gap-2 text-ink-600">
          <Icon name="shield-info" size={16} />
          <span>{contacts.responsibleUnit}</span>
        </span>
      </div>
    </div>

    <div
      class="mt-10 flex justify-center border-t border-ink-200 pt-6 text-center text-xs text-ink-500"
    >
      <span>© {year} МГТУ.</span>
    </div>
  </Container>
</footer>
