---
import Container from './ui/Container.astro';
---

<section id="directions" class="directions-statement anchor-offset">
  <Container class="!max-w-[1440px]">
    <p class="directions-statement__text">
      Сегодня в России формируется новый род войск — подразделения беспилотных
      авиационных систем. Это направление уже сейчас играет ключевую роль в
      обеспечении безопасности страны и открывает новые профессиональные
      возможности, в том числе для молодежи с техническим образованием.
    </p>
  </Container>
</section>

<style>
  .directions-statement {
    background: #f8fafc;
    padding-block: clamp(52px, 6vw, 92px);
  }

  .directions-statement__text {
    margin: 0 auto;
    max-width: 1320px;
    color: #111827;
    font-size: clamp(1.7rem, 2.55vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.14;
    text-align: center;
    text-wrap: balance;
  }

  @media (max-width: 767px) {
    .directions-statement {
      padding-block: 44px;
    }

    .directions-statement__text {
      font-size: clamp(1.35rem, 6vw, 1.9rem);
      line-height: 1.18;
    }
  }
</style>
