---
import Container from './ui/Container.astro';
import SectionTitle from './ui/SectionTitle.astro';
import Card from './ui/Card.astro';
import Icon from './ui/Icon.astro';
import Button from './ui/Button.astro';
import { contacts } from '../data/contacts';
import { site } from '../data/site';
---

<section id="contacts" class="section contact-section anchor-offset">
  <Container class="grid gap-10 lg:grid-cols-12">
    <div class="lg:col-span-5 flex flex-col gap-6">
      <SectionTitle
        class="contact-section__title"
        title="Запишитесь на консультацию"
        subtitle="Заполните короткую форму или свяжитесь напрямую. Мы перезвоним и спокойно ответим на ваши вопросы. Заявка не обязывает к подписанию каких-либо документов."
      />

      <Card variant="soft" class="contact-card contact-info-card flex flex-col gap-4">
        <div class="grid gap-3 text-sm">
          <a
            href={contacts.phoneHref}
            class="contact-row flex items-center gap-3 group"
          >
            <span class="contact-row__icon inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-ink-200 text-brand-700">
              <Icon name="phone" size={20} />
            </span>
            <div>
              <div class="contact-row__label text-xs uppercase tracking-wider text-ink-500">
                Телефон
              </div>
              <div class="contact-row__value text-base font-medium text-ink-900 group-hover:text-brand-800">
                {contacts.phone}
              </div>
            </div>
          </a>
          <a
            href={`mailto:${contacts.email}`}
            class="contact-row flex items-center gap-3 group"
          >
            <span class="contact-row__icon inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-ink-200 text-brand-700">
              <Icon name="mail" size={20} />
            </span>
            <div>
              <div class="contact-row__label text-xs uppercase tracking-wider text-ink-500">
                Email
              </div>
              <div class="contact-row__value text-base font-medium text-ink-900 group-hover:text-brand-800">
                {contacts.email}
              </div>
            </div>
          </a>
          <div class="contact-row flex items-center gap-3">
            <span class="contact-row__icon inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-ink-200 text-brand-700">
              <Icon name="pin" size={20} />
            </span>
            <div>
              <div class="contact-row__label text-xs uppercase tracking-wider text-ink-500">
                Адрес
              </div>
              <div class="contact-row__value text-base font-medium text-ink-900">
                {contacts.address}
              </div>
            </div>
          </div>
          <div class="contact-row flex items-center gap-3">
            <span class="contact-row__icon inline-flex h-10 w-10 items-center justify-center rounded-xl bg-white border border-ink-200 text-brand-700">
              <Icon name="clock" size={20} />
            </span>
            <div>
              <div class="contact-row__label text-xs uppercase tracking-wider text-ink-500">
                График работы
              </div>
              <div class="contact-row__value text-base font-medium text-ink-900">
                {contacts.workingHours}
              </div>
            </div>
          </div>
        </div>

        <div class="contact-unit rounded-xl bg-white border border-ink-200 px-3 py-2.5 text-sm">
          <span class="contact-row__label text-xs uppercase tracking-wider text-ink-500">
            Ответственное подразделение
          </span>
          <div class="contact-row__value text-ink-800 font-medium">
            {contacts.responsibleUnit}
          </div>
        </div>

      </Card>
    </div>

    <div class="lg:col-span-7 flex">
      <Card class="contact-card contact-form-card flex flex-col gap-5 w-full h-full" variant="default">
        <form
          id="contact-form"
          action="/api/contact"
          method="POST"
          novalidate
          class="contact-form grid gap-4 sm:grid-cols-2"
        >
          <div class="sm:col-span-2">
            <label for="name" class="contact-label block text-sm font-medium text-ink-800">
              ФИО <span class="text-accent-red">*</span>
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="contact-field mt-1.5 block w-full rounded-xl border border-ink-200 bg-white px-3.5 py-2.5 text-base text-ink-900 placeholder:text-ink-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/20"
              placeholder="Введите ФИО"
            />
          </div>

          <div class="sm:col-span-1">
            <label for="phone" class="contact-label block text-sm font-medium text-ink-800">
              Телефон <span class="text-accent-red">*</span>
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              required
              autocomplete="tel"
              inputmode="tel"
              class="contact-field mt-1.5 block w-full rounded-xl border border-ink-200 bg-white px-3.5 py-2.5 text-base text-ink-900 placeholder:text-ink-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/20"
              placeholder="+7 ___ ___ __ __"
            />
          </div>

          <div class="sm:col-span-1">
            <label for="email" class="contact-label block text-sm font-medium text-ink-800">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              class="contact-field mt-1.5 block w-full rounded-xl border border-ink-200 bg-white px-3.5 py-2.5 text-base text-ink-900 placeholder:text-ink-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/20"
              placeholder="you@example.com"
            />
          </div>

          <div class="sm:col-span-2">
            <label for="status" class="contact-label block text-sm font-medium text-ink-800">
              Статус студента
            </label>
            <select
              id="status"
              name="status"
              class="contact-field mt-1.5 block w-full rounded-xl border border-ink-200 bg-white px-3.5 py-2.5 text-base text-ink-900 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/20"
            >
              <option value="">Выберите вариант</option>
              <option value="bachelor">Бакалавриат</option>
              <option value="specialist">Специалитет</option>
              <option value="master">Магистратура</option>
              <option value="postgrad">Аспирантура</option>
              <option value="college">Колледж / СПО</option>
              <option value="other">Другое</option>
            </select>
          </div>

          <div class="sm:col-span-2">
            <label
              for="comment"
              class="contact-label block text-sm font-medium text-ink-800"
            >
              Комментарий
            </label>
            <textarea
              id="comment"
              name="comment"
              rows="4"
              class="contact-field mt-1.5 block w-full rounded-xl border border-ink-200 bg-white px-3.5 py-2.5 text-base text-ink-900 placeholder:text-ink-400 focus:border-brand-500 focus:outline-none focus:ring-4 focus:ring-brand-500/20"
              placeholder="Если есть конкретные вопросы — напишите здесь"
            ></textarea>
          </div>

          <div class="sm:col-span-2">
            <label class="contact-consent flex items-start gap-3 text-sm text-ink-700">
              <input
                type="checkbox"
                name="consent"
                required
                class="mt-1 h-5 w-5 rounded border-ink-300 text-brand-700 focus:ring-brand-500"
              />
              <span>
                Я соглашаюсь на обработку персональных данных в соответствии с
                <a href="#" class="text-brand-800 underline hover:text-brand-900">
                  политикой обработки персональных данных
                </a>
                {site.shortName}.
              </span>
            </label>
          </div>

          <div class="contact-submit-row sm:col-span-2 flex flex-col-reverse sm:flex-row sm:items-center gap-3 sm:gap-4">
            <p
              id="form-status"
              class="text-sm text-ink-600 min-h-[1.25rem]"
              role="status"
              aria-live="polite"
            >
            </p>
            <Button type="submit" size="lg" class="sm:ml-auto">
              Оставить заявку
              <Icon name="arrow-right" size={18} />
            </Button>
          </div>
        </form>
      </Card>
    </div>
  </Container>
</section>

<style>
  :global(.contact-section__title h2) {
    color: #004329;
    font-weight: 600;
    line-height: 1.02;
  }

  :global(.contact-section__title p) {
    max-width: 34rem;
    color: rgb(15 23 42 / 0.72);
    font-size: clamp(1rem, 1.04vw, 1.12rem);
    font-weight: 400;
    line-height: 1.52;
  }

  :global(.contact-card) {
    border: 1px solid rgb(15 23 42 / 0.16);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.76), rgb(255 255 255 / 0.52)),
      rgb(255 255 255 / 0.44);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.78),
      0 16px 36px rgb(15 23 42 / 0.06);
  }

  :global(.contact-info-card) {
    padding: clamp(18px, 1.8vw, 24px);
  }

  :global(.contact-form-card) {
    padding: clamp(20px, 2.25vw, 30px);
  }

  :global(.contact-form) {
    min-height: 100%;
  }

  :global(.contact-submit-row) {
    align-self: end;
  }

  :global(.contact-row) {
    border-radius: 8px;
    padding: 8px;
    transition:
      background-color 180ms ease,
      transform 180ms ease;
  }

  :global(.contact-row:hover) {
    background: rgb(255 255 255 / 0.5);
    transform: translateY(-1px);
  }

  :global(.contact-row__icon) {
    flex: 0 0 auto;
    border-color: rgb(15 23 42 / 0.14);
    border-radius: 8px;
    background: rgb(255 255 255 / 0.72);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.82);
  }

  :global(.contact-row__label),
  :global(.contact-label) {
    color: rgb(0 67 41 / 0.78);
    font-weight: 500;
  }

  :global(.contact-row__value) {
    color: #0f172a;
    font-weight: 400;
    line-height: 1.25;
  }

  :global(.contact-unit) {
    border-color: rgb(15 23 42 / 0.14);
    border-radius: 8px;
    background: rgb(255 255 255 / 0.55);
  }

  :global(.contact-field) {
    min-height: 48px;
    border-color: rgb(15 23 42 / 0.16);
    border-radius: 8px;
    background: rgb(255 255 255 / 0.68);
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.72);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  :global(.contact-field:focus) {
    border-color: rgb(29 78 216 / 0.45);
    background: rgb(255 255 255 / 0.92);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.82),
      0 0 0 4px rgb(29 78 216 / 0.12);
  }

  :global(.contact-consent) {
    color: rgb(15 23 42 / 0.72);
    font-weight: 400;
    line-height: 1.45;
  }

  :global(html[data-theme='dark'] .contact-section__title h2) {
    color: #ffffff;
  }

  :global(html[data-theme='dark'] .contact-section__title p),
  :global(html[data-theme='dark'] .contact-consent) {
    color: #dbe4ef;
  }

  :global(html[data-theme='dark'] .contact-card) {
    border-color: rgb(148 163 184 / 0.22);
    background:
      linear-gradient(180deg, rgb(15 23 42 / 0.86), rgb(15 23 42 / 0.62)),
      rgb(15 23 42 / 0.72);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 18px 42px rgb(0 0 0 / 0.22);
  }

  :global(html[data-theme='dark'] .contact-row:hover) {
    background: rgb(255 255 255 / 0.05);
  }

  :global(html[data-theme='dark'] .contact-row__icon),
  :global(html[data-theme='dark'] .contact-unit) {
    border-color: rgb(148 163 184 / 0.24) !important;
    background: rgb(15 23 42 / 0.78) !important;
  }

  :global(html[data-theme='dark'] .contact-row__label),
  :global(html[data-theme='dark'] .contact-label) {
    color: #bfdbfe !important;
  }

  :global(html[data-theme='dark'] .contact-row__value) {
    color: #f8fafc !important;
  }

  :global(html[data-theme='dark'] .contact-field) {
    border-color: rgb(148 163 184 / 0.24) !important;
    background: rgb(15 23 42 / 0.78) !important;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.06);
  }

  :global(html[data-theme='dark'] .contact-field:focus) {
    border-color: rgb(147 197 253 / 0.5) !important;
    background: rgb(15 23 42 / 0.92) !important;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 0 0 4px rgb(96 165 250 / 0.16);
  }

  @media (max-width: 640px) {
    :global(.contact-row) {
      padding: 6px 0;
    }

    :global(.contact-form-card) {
      padding: 18px;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = 'Отправляем заявку…';
      status.className = 'text-sm text-ink-600 min-h-[1.25rem]';

      const data = new FormData(form);
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error('network');
        status.textContent =
          'Спасибо! Заявка получена. Мы свяжемся с вами в рабочее время.';
        status.className = 'text-sm text-brand-800 min-h-[1.25rem] font-medium';
        form.reset();
      } catch {
        status.textContent =
          'Не удалось отправить заявку. Попробуйте позже или напишите напрямую.';
        status.className = 'text-sm text-accent-red min-h-[1.25rem] font-medium';
      }
    });
  }
</script>
